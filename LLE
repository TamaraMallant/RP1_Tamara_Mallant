for (stype in p1_sample_types) {
  cat(sprintf("--- Sample type: %s ---\n", stype))
  p1_results[[stype]] <- list()
  p1_IS[[stype]]      <- list()
  
  for (sv in solvent_names) {
    cat(sprintf("  Solvent: %s\n", sv))
    sv_cols <- sample_cols_by_type[[stype]][[sv]]
    df <- raw_all %>% select(mz, mean_general_blank, all_of(sv_cols))
    
