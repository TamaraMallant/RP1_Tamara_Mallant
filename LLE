count_zeros <- function(df, cols) {
  rowSums(df[, cols, drop = FALSE] == 0, na.rm = TRUE)
}

row_mean <- function(df, cols) {
  rowMeans(df[, cols, drop = FALSE], na.rm = TRUE)
}

row_sd <- function(df, cols) {
  apply(df[, cols, drop = FALSE], 1, sd, na.rm = TRUE)
}

# Blank subtraction: (sample_mean + 1) / (blank_mean + 1) >= fc_threshold
passes_fc <- function(df, sample_cols, blank_cols, threshold = fc_threshold) {
  smean <- row_mean(df, sample_cols)
  bmean <- row_mean(df, blank_cols)
  (smean + 1) / (bmean + 1) >= threshold
}

match_db <- function(df, db_df, mz_col_db, ppm_tol = ppm_tolerance) {
  # Returns a list of data frames, one per matching hit (may be multiple per feature)
  result <- lapply(seq_len(nrow(df)), function(i) {
    measured   <- df$mz[i]
    ppm_errors <- ((measured - db_df[[mz_col_db]]) / db_df[[mz_col_db]]) * 1e6
    hits       <- which(abs(ppm_errors) <= ppm_tol)
    if (length(hits) == 0L) return(NULL)
    do.call(rbind, lapply(hits, function(h) {
      cbind(df[i, , drop = FALSE],
            db_df[h, , drop = FALSE],
            ppm_error = round(ppm_errors[h], 3))
    }))
  })
  bind_rows(result)
}

pareto_scale <- function(mat) {
  scaled <- t(apply(mat, 1, function(x) {
    mu  <- mean(x, na.rm = TRUE)
    sig <- sd(x,   na.rm = TRUE)
    if (is.na(mu) || is.na(sig) || sig == 0) return(x - mu)
    (x - mu) / sqrt(sig)
  }))
  colnames(scaled) <- colnames(mat)
  scaled
}

run_ttest <- function(x, y) {
  x <- as.numeric(x[!is.na(x)]); y <- as.numeric(y[!is.na(y)])
  if (length(x) < 2 || length(y) < 2) return(NA_real_)
  alt <- if (mean(x) > mean(y)) "greater" else "less"
  tryCatch(t.test(x, y, alternative = alt, var.equal = FALSE)$p.value,
           error = function(e) NA_real_)
}

# Two-sided t-test — used for significance brackets on boxplots
run_ttest_2sided <- function(x, y) {
  x <- as.numeric(x[!is.na(x)]); y <- as.numeric(y[!is.na(y)])
  if (length(x) < 2 || length(y) < 2) return(NA_real_)
  tryCatch(t.test(x, y, alternative = "two.sided", var.equal = FALSE)$p.value,
           error = function(e) NA_real_)
}

sig_label <- function(p) {
  if (is.na(p))  return("ns")
  if (p < 0.001) return("***")
  if (p < 0.01)  return("**")
  if (p < 0.05)  return("*")
  return("ns")
}

# Two-sided t-test p-value comparing one grouping variable's two levels,
# on a value column, within a data frame
ttest_pair <- function(df, group_col, val_col, g1, g2) {
  x <- df[[val_col]][df[[group_col]] == g1]
  y <- df[[val_col]][df[[group_col]] == g2]
  run_ttest_2sided(x, y)
}

# Build significance-bracket data for a dodged boxplot of
# solvent (x-axis) x sample_type (fill/dodge), value column val_col.
#
# Returns a data frame with columns: x, xend, y, label — ready for
# geom_segment + geom_text. Two sets of comparisons:
#   - within-solvent : p1_sample_types[1] vs p1_sample_types[2] (e.g. EV_LLE vs blank_LLE),
#                       one bracket per solvent, placed just above that
#                       solvent's boxes.
#   - across-solvent : p1_sample_types[1] (e.g. EV_LLE) compared pairwise
#                       across solvents, placed above the within-solvent
#                       brackets.
# Only brackets with p < 0.05 are returned (ns comparisons are omitted).
build_sig_brackets <- function(df, val_col, solvent_levels, type_levels,
                               dodge_width = 0.75) {
  n_types <- length(type_levels)
  # Dodge offset for 2 groups: each box centred at +/- dodge_width/4
  half_offsets <- (seq_len(n_types) - (n_types + 1) / 2) * (dodge_width / n_types)
  pos_by_type  <- setNames(half_offsets, type_levels)
  
  y_max  <- max(df[[val_col]], na.rm = TRUE)
  y_rng  <- diff(range(df[[val_col]], na.rm = TRUE))
  y_step <- if (is.finite(y_rng) && y_rng > 0) y_rng * 0.08 else 0.1
  
  brackets <- list()
  
  # --- Within-solvent: type_levels[1] vs type_levels[2], per solvent ---
  if (n_types >= 2) {
    for (sv in solvent_levels) {
      sv_idx <- match(sv, solvent_levels)
      sub <- df[df$solvent == sv, ]
      p   <- ttest_pair(sub, "sample_type", val_col, type_levels[1], type_levels[2])
      if (!is.na(p) && p < 0.05) {
        brackets[[length(brackets) + 1]] <- data.frame(
          x      = sv_idx + unname(pos_by_type[type_levels[1]]),
          xend   = sv_idx + unname(pos_by_type[type_levels[2]]),
          y      = y_max + y_step,
          label  = sig_label(p),
          tier   = "within",
          stringsAsFactors = FALSE)
      }
    }
  }
  
  # --- Across-solvent: type_levels[1] (e.g. EV_LLE) across solvent pairs ---
  if (length(solvent_levels) >= 2) {
    pairs <- combn(seq_along(solvent_levels), 2, simplify = FALSE)
    tier_y <- y_max + y_step * 2
    for (pr in pairs) {
      sv1 <- solvent_levels[pr[1]]; sv2 <- solvent_levels[pr[2]]
      sub1 <- df[df$solvent == sv1 & df$sample_type == type_levels[1], ]
      sub2 <- df[df$solvent == sv2 & df$sample_type == type_levels[1], ]
      p <- run_ttest_2sided(sub1[[val_col]], sub2[[val_col]])
      if (!is.na(p) && p < 0.05) {
        brackets[[length(brackets) + 1]] <- data.frame(
          x      = pr[1] + unname(pos_by_type[type_levels[1]]),
          xend   = pr[2] + unname(pos_by_type[type_levels[1]]),
          y      = tier_y,
          label  = sig_label(p),
          tier   = "across",
          stringsAsFactors = FALSE)
        tier_y <- tier_y + y_step
      }
    }
  }
  
  if (length(brackets) == 0) return(NULL)
  bind_rows(brackets)
}

# Add significance bracket layers (geom_segment + geom_text) to a ggplot,
# and expand the y-axis to make room. sig_df is the output of
# build_sig_brackets(); if NULL, returns p unchanged.
add_sig_layers <- function(p, sig_df, df, val_col, text_size = 3) {
  if (is.null(sig_df)) return(p)
  y_max <- max(df[[val_col]], na.rm = TRUE)
  y_rng <- diff(range(df[[val_col]], na.rm = TRUE))
  y_step <- if (is.finite(y_rng) && y_rng > 0) y_rng * 0.08 else 0.1
  y_top  <- max(sig_df$y) + y_step * 1.5
  
  p +
    geom_segment(data = sig_df,
                 aes(x = x, xend = xend, y = y, yend = y),
                 inherit.aes = FALSE, linewidth = 0.4) +
    geom_text(data = sig_df,
              aes(x = (x + xend) / 2, y = y + y_step * 0.25, label = label),
              inherit.aes = FALSE, size = text_size) +
    expand_limits(y = y_top)
}

# ---------------------------------------------------------------------------
# log2FC annotation helpers for the Part 1 boxplots.
# The reference-blank abundances are pulled per is_name × solvent:
#   - "blank_LLE"    : taken straight from the plot long-table (p1_long)
#   - "general_blank": IS-matched against the shared general_blank columns
#                      (general_blank is solvent-independent, so the same
#                      values are used for every solvent)
# ---------------------------------------------------------------------------
get_blank_abu_long <- function(ref) {
  if (ref == "blank_LLE") {
    p1_long %>%
      filter(sample_type == "blank_LLE") %>%
      select(is_name, solvent, abundance)
  } else if (ref == "general_blank") {
    gb    <- raw_all %>% select(mz, all_of(general_blank_cols))
    gb_is <- match_db(gb, is_ref, "is_mz", ppm_tol = ppm_tolerance)
    if (is.null(gb_is) || nrow(gb_is) == 0) return(NULL)
    gb_long <- gb_is %>%
      select(is_name, all_of(general_blank_cols)) %>%
      pivot_longer(-is_name, names_to = "rep", values_to = "abundance") %>%
      filter(!is.na(abundance), abundance > 0) %>%
      select(is_name, abundance)
    # Shared across solvents -> replicate the same values for each solvent
    tidyr::crossing(solvent = solvent_names, gb_long) %>%
      select(is_name, solvent, abundance)
  } else {
    stop("boxplot_log2fc_ref must be 'general_blank' or 'blank_LLE'")
  }
}

# Compute log2FC = log2((mean EV + 1)/(mean blank + 1)) per grouping.
# per_lipid = FALSE -> one value per solvent (for the total-IS boxplot)
# per_lipid = TRUE  -> one value per is_name × solvent (per-lipid boxplots)
compute_box_log2fc <- function(box_long, blank_long, per_lipid = FALSE) {
  if (is.null(blank_long) || nrow(blank_long) == 0) return(NULL)
  grp <- if (per_lipid) c("is_name", "solvent") else "solvent"
  ev_mean <- box_long %>%
    filter(sample_type == "EV_LLE") %>%
    group_by(across(all_of(grp))) %>%
    summarise(ev = mean(abundance, na.rm = TRUE), .groups = "drop")
  bl_mean <- blank_long %>%
    group_by(across(all_of(grp))) %>%
    summarise(bl = mean(abundance, na.rm = TRUE), .groups = "drop")
  left_join(ev_mean, bl_mean, by = grp) %>%
    filter(!is.na(ev)) %>%
    mutate(log2fc = log2((ev + 1) / (bl + 1)))
}

# Add the log2FC numbers above each solvent's EV_LLE box.
add_log2fc_layer <- function(p, fc_df, box_long, val_col, type_levels,
                             solvent_levels, dodge_width = 0.75, text_size = 3) {
  if (is.null(fc_df) || nrow(fc_df) == 0) return(p)
  n_types      <- length(type_levels)
  half_offsets <- (seq_len(n_types) - (n_types + 1) / 2) * (dodge_width / n_types)
  ev_off       <- if ("EV_LLE" %in% type_levels)
    half_offsets[match("EV_LLE", type_levels)] else 0
  y_max  <- max(box_long[[val_col]], na.rm = TRUE)
  y_rng  <- diff(range(box_long[[val_col]], na.rm = TRUE))
  y_step <- if (is.finite(y_rng) && y_rng > 0) y_rng * 0.05 else 0.1
  fc_df <- fc_df %>%
    mutate(x     = match(as.character(solvent), solvent_levels) + ev_off,
           y     = y_max + y_step,
           label = sprintf("%+.1f", log2fc))
  p +
    geom_text(data = fc_df, aes(x = x, y = y, label = label),
              inherit.aes = FALSE, size = text_size, colour = "grey25",
              fontface = "italic") +
    expand_limits(y = y_max + y_step * 2.5)
}

color_cov_column <- function(wb, sheet, col_index, cov_vals, start_row = 2) {
  styles <- list(
    green  = createStyle(fgFill = "#00B050"),
    yellow = createStyle(fgFill = "#FFFF00"),
    red    = createStyle(fgFill = "#FF0000"))
  for (i in seq_along(cov_vals)) {
    v <- cov_vals[i]
    s <- if (!is.na(v) && v <  30) styles$green  else
      if (!is.na(v) && v <= 50) styles$yellow else styles$red
    addStyle(wb, sheet, s, rows = start_row + i - 1, cols = col_index)
  }
}

write_results_xlsx <- function(df, file, cov_cols = NULL) {
