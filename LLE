# Filesystem-safe name: replace anything that isn't alphanumeric, dot, dash or
# underscore (covers spaces, colons, slashes, parentheses in IS lipid names),
# then collapse repeats and trim leading/trailing underscores.
safe_name <- function(x) {
  x <- gsub("[^A-Za-z0-9._-]", "_", x)
  x <- gsub("_+", "_", x)
  gsub("^_|_$", "", x)
}

# Robust lipid label: sum composition synonym, falling back to common name,
# then systematic name, then LipidMaps ID. Ensures every matched feature gets
# a non-NA, non-blank label (nothing is ever dropped from collapsed tables).
lipid_label_fallback <- function(sum_comp, common_name, systematic_name, lm_id) {
  sum_comp        <- as.character(sum_comp)
  common_name     <- as.character(common_name)
  systematic_name <- as.character(systematic_name)
  lm_id           <- as.character(lm_id)
  
  is_blank <- function(x) is.na(x) | trimws(x) == ""
  
  label <- sum_comp
  use_common <- is_blank(label)
  label[use_common] <- common_name[use_common]
  
  use_systematic <- is_blank(label)
  label[use_systematic] <- systematic_name[use_systematic]
  
  use_id <- is_blank(label)
  label[use_id] <- lm_id[use_id]
  
  label
}

