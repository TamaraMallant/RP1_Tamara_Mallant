# =============================================================================
# PART 2: EV-SPECIFIC LIPID IDENTIFICATION (LipidMaps)
# =============================================================================
cat("========================================\n")
cat("PART 2: EV lipid identification\n")
cat("========================================\n\n")

# For each solvent: retain EV_LLE features that pass FC >= fc_threshold
# vs ALL THREE of: blank_LLE, general_blank, blank_splash.
# Then match retained features to LipidMaps database.

p2_ev_filtered <- list()   # [[solvent]] = EV features passing all FC filters
p2_lm_matched  <- list()   # [[solvent]] = LipidMaps-matched features

lm_mz_col_r <- "lm_mz"  # renamed column in lm_db

for (sv in solvent_names) {
  cat(sprintf("--- Solvent: %s ---\n", sv))
  
  ev_cols      <- EV_LLE_by_sv[[sv]]
  bLLE_cols    <- blank_LLE_by_sv[[sv]]
  bSplash_cols <- blank_splash_by_sv[[sv]]
  
  # Start from raw data, pull all relevant columns
  df <- raw_all %>%
    select(mz, mean_general_blank,
           all_of(ev_cols), all_of(bLLE_cols), all_of(bSplash_cols))
  
  # Missingness filter on EV_LLE replicates
  miss_fail <- count_zeros(df, ev_cols) >= missingness_count
  df <- df[!miss_fail, ]
  cat(sprintf("  After missingness         : %d\n", nrow(df)))
  
  # Abundance filter on EV_LLE mean
  df$mean_EV <- row_mean(df, ev_cols)
  df <- df[df$mean_EV >= abundance_threshold, ]
  cat(sprintf("  After abundance filter    : %d\n", nrow(df)))
  
  # FC filter: EV_LLE vs general_blank
  fc_vs_gblank  <- passes_fc(df, ev_cols, "mean_general_blank")
  # FC filter: EV_LLE vs blank_LLE (per-solvent)
  fc_vs_bLLE    <- passes_fc(df, ev_cols, bLLE_cols)
  # FC filter: EV_LLE vs blank_splash (per-solvent)
  fc_vs_bSplash <- passes_fc(df, ev_cols, bSplash_cols)
  
  # Must pass ALL three
  fc_all <- fc_vs_gblank & fc_vs_bLLE & fc_vs_bSplash
  df <- df[fc_all, ]
  cat(sprintf("  After FC (all 3 blanks)   : %d\n", nrow(df)))
  
  # CoV on EV_LLE replicates
  cov_col <- paste0("CoV_pct_EV_", sv)
  df[[cov_col]] <- row_sd(df, ev_cols) / df$mean_EV * 100
  v <- df[[cov_col]]
  cat(sprintf("  CoV <30%%: %d | 30-50%%: %d | >50%%: %d\n",
              sum(v < 30, na.rm=TRUE), sum(v >= 30 & v <= 50, na.rm=TRUE),
              sum(v > 50, na.rm=TRUE)))
  
  if (filter_high_cov) {
    df <- df[is.na(v) | v <= cov_threshold, ]
    cat(sprintf("  After CoV filter          : %d\n", nrow(df)))
  }
  
  # Add log2FC columns for transparency
  df$log2FC_vs_gblank  <- round(log2((df$mean_EV + 1) /
                                       (row_mean(df, "mean_general_blank") + 1)), 3)
  df$log2FC_vs_bLLE    <- round(log2((df$mean_EV + 1) /
                                       (row_mean(df, bLLE_cols) + 1)), 3)
  df$log2FC_vs_bSplash <- round(log2((df$mean_EV + 1) /
                                       (row_mean(df, bSplash_cols) + 1)), 3)
  
  p2_ev_filtered[[sv]] <- df
  
  write_results_xlsx(df,
                     sprintf("P2_EV_%s_%s_filtered.xlsx", safe_name(sv), mode),
                     cov_cols = cov_col)
  
  # LipidMaps matching
  lm_sub <- match_db(df, lm_db, lm_mz_col_r, ppm_tol = ppm_tolerance_lipidmaps)
  cat(sprintf("  LipidMaps-matched         : %d rows\n", nrow(lm_sub)))
  p2_lm_matched[[sv]] <- lm_sub
  
  if (nrow(lm_sub) > 0) {
    write_results_xlsx(lm_sub,
                       sprintf("P2_EV_%s_%s_LipidMaps.xlsx", safe_name(sv), mode),
                       cov_cols = grep("CoV", colnames(lm_sub), value = TRUE))
    
    # Collapsed by sum composition (e.g. "PC 36:1")
    # Falls back to common name, then systematic name, then LipidMaps ID,
    # so every matched feature is retained under some label.
    lm_collapsed <- lm_sub %>%
      mutate(lipid_label = lipid_label_fallback(
        lm_sum_comp, lm_common_name, lm_systematic, lm_id)) %>%
      group_by(lipid_label) %>%
      summarise(
        n_features      = n(),
        mz_min          = round(min(mz, na.rm = TRUE), 4),
        mz_max          = round(max(mz, na.rm = TRUE), 4),
        mean_abundance  = round(sum(mean_EV, na.rm = TRUE), 1),
        mean_ppm_error  = round(mean(ppm_error, na.rm = TRUE), 3),
        category        = paste(unique(na.omit(lm_category)),  collapse = "; "),
        main_class      = paste(unique(na.omit(lm_main_class)), collapse = "; "),
        sub_class       = paste(unique(na.omit(lm_sub_class)),  collapse = "; "),
        lipidmaps_ids   = paste(unique(na.omit(lm_id)), collapse = "; "),
        .groups = "drop") %>%
      arrange(desc(mean_abundance))
    
    write_results_xlsx(lm_collapsed,
                       sprintf("P2_EV_%s_%s_LipidMaps_collapsed.xlsx", safe_name(sv), mode))
    cat(sprintf("  Collapsed sum-comp lipids : %d\n", nrow(lm_collapsed)))
  }
  cat("\n")
}

# =============================================================================
# PART 2 — HEATMAP: Sum-composition lipids × solvent replicates
# =============================================================================
cat("Part 2 — Heatmap: sum-composition lipids × solvent replicates...\n\n")

# Collapse: for each solvent × sum_comp, sum each EV_LLE replicate's
# abundance separately (heatmap rows = sum-comp lipid species,
# columns = one per solvent replicate)

p2_heatmap_data <- bind_rows(lapply(solvent_names, function(sv) {
  lm <- p2_lm_matched[[sv]]
  if (is.null(lm) || nrow(lm) == 0) return(NULL)
  
  # Robust label: sum composition synonym, falling back to common name,
  # systematic name, then LipidMaps ID — nothing is ever dropped here.
  lm <- lm %>%
    mutate(lipid_label = lipid_label_fallback(
      lm_sum_comp, lm_common_name, lm_systematic, lm_id))
  
  ev_cols <- EV_LLE_by_sv[[sv]]
  
  # Sum each replicate column per lipid_label (in case multiple m/z hits
  # map to the same sum-composition label)
  lm %>%
    group_by(lipid_label) %>%
    summarise(across(all_of(ev_cols), ~ sum(.x, na.rm = TRUE)), .groups = "drop") %>%
    rename_with(~ paste0(sv, "_rep", seq_along(ev_cols)), all_of(ev_cols)) %>%
    mutate(solvent = sv)
}))

if (!is.null(p2_heatmap_data) && nrow(p2_heatmap_data) > 0) {
  
  # Replicate column labels in solvent x replicate order
  rep_col_labels <- unlist(lapply(solvent_names,
                                  function(sv) paste0(sv, "_rep", seq_len(n_replicates))))
  
  # Merge per-solvent wide frames into one wide table (rows = lipid_label,
  # cols = all replicate columns across all solvents)
  mat_p2_df <- p2_heatmap_data %>%
    select(-solvent) %>%
    group_by(lipid_label) %>%
    summarise(across(everything(), ~ sum(.x, na.rm = TRUE)), .groups = "drop")
  
  mat_p2 <- mat_p2_df %>%
    tibble::column_to_rownames("lipid_label") %>%
    as.matrix()
  
  # Ensure all expected replicate columns exist (fill missing with 0) and
  # order columns as solvent x replicate
  missing_cols <- setdiff(rep_col_labels, colnames(mat_p2))
  if (length(missing_cols) > 0) {
    fill_mat <- matrix(0, nrow = nrow(mat_p2), ncol = length(missing_cols),
                       dimnames = list(rownames(mat_p2), missing_cols))
    mat_p2 <- cbind(mat_p2, fill_mat)
  }
  mat_p2 <- mat_p2[, rep_col_labels, drop = FALSE]
  
  # Build a lipid_label -> category lookup (one category per label).
  # If a label maps to multiple categories across solvents/hits, take the
  # first alphabetically for a stable, single grouping.
  label_category <- bind_rows(lapply(solvent_names, function(sv) {
    lm <- p2_lm_matched[[sv]]
    if (is.null(lm) || nrow(lm) == 0) return(NULL)
    lm %>%
      mutate(lipid_label = lipid_label_fallback(
        lm_sum_comp, lm_common_name, lm_systematic, lm_id)) %>%
      select(lipid_label, lm_category)
  })) %>%
    mutate(lm_category = if_else(is.na(lm_category) | trimws(lm_category) == "",
                                 "Uncategorized", lm_category)) %>%
    group_by(lipid_label) %>%
    summarise(category = sort(unique(lm_category))[1], .groups = "drop")
  
  # Apply heatmap_categories filter (NULL or "all" = keep everything)
  if (!is.null(heatmap_categories) && !identical(heatmap_categories, "all")) {
    keep_labels <- label_category$lipid_label[label_category$category %in% heatmap_categories]
    # Labels with no LipidMaps match at all (shouldn't normally happen here,
    # but handled for completeness) are "Uncategorized"
    no_cat_labels <- setdiff(rownames(mat_p2), label_category$lipid_label)
    if ("Uncategorized" %in% heatmap_categories) keep_labels <- c(keep_labels, no_cat_labels)
    
    n_before <- nrow(mat_p2)
    mat_p2 <- mat_p2[rownames(mat_p2) %in% keep_labels, , drop = FALSE]
    cat(sprintf("  heatmap_categories filter: %d -> %d lipids (categories: %s)\n",
                n_before, nrow(mat_p2), paste(heatmap_categories, collapse = ", ")))
  }
  
  if (nrow(mat_p2) == 0) {
    cat("  WARNING: heatmap_categories filter removed all lipids — heatmaps skipped.\n")
  } else {
    
    log2_p2 <- log2(mat_p2 + 1)
    log2_p2[!is.finite(log2_p2)] <- 0
    
    scaled_p2 <- if (pareto_scaling) pareto_scale(log2_p2) else log2_p2
    
    # Clustering
    if (nrow(scaled_p2) > 1) {
      row_ord_p2 <- rownames(scaled_p2)[
        hclust(dist(scaled_p2), method = "complete")$order]
    } else {
      row_ord_p2 <- rownames(scaled_p2)
    }
    
    long_p2 <- data.frame(
      lipid   = rep(rownames(scaled_p2), times = ncol(scaled_p2)),
      x_label = rep(colnames(scaled_p2), each  = nrow(scaled_p2)),
      value   = as.vector(scaled_p2)
    ) %>%
      mutate(
        lipid   = factor(lipid,   levels = rev(row_ord_p2)),
        x_label = factor(x_label, levels = rep_col_labels))
    
    # Vertical separators between solvent blocks (each block = n_replicates cols)
    x_sep_p2 <- cumsum(rep(n_replicates, n_solvents))
    x_sep_p2 <- x_sep_p2[-length(x_sep_p2)] + 0.5
    
    sl2 <- max(abs(range(long_p2$value, na.rm = TRUE)))
    ph2 <- max(6, nrow(scaled_p2) * 0.28)
    pw2 <- length(rep_col_labels) * 0.6 + 4
    
    p_heat2 <- ggplot(long_p2, aes(x = x_label, y = lipid, fill = value)) +
      geom_tile(colour = "white", linewidth = 0.25) +
      { lapply(x_sep_p2, function(xs)
        geom_vline(xintercept = xs, colour = "grey30", linewidth = 0.8)) } +
      scale_fill_gradientn(colours = heatmap_colours, limits = c(-sl2, sl2),
                           na.value = "grey85",
                           name = if (pareto_scaling) "Pareto-scaled\nlog2" else "log2(sum abu + 1)") +
      scale_x_discrete(position = "top") +
      scale_y_discrete(expand = c(0, 0)) +
      labs(
        title    = sprintf("EV lipidome — sum-composition species × solvent replicates (%s mode)",
                           toupper(mode)),
        subtitle = paste0(
          "EV_LLE filtered vs blank_LLE + general_blank + blank_splash (FC ≥ ", fc_threshold, ")\n",
          if (pareto_scaling) "log2(sum abu) | Pareto scaled" else "log2(sum abu)",
          " | rows by complete-linkage clustering | LipidMaps matched (±", ppm_tolerance_lipidmaps, " ppm)"),
        x = "Solvent replicate", y = "Sum-composition lipid") +
      theme_minimal(base_size = 10) +
      theme(
        axis.text.x       = element_text(angle = 45, hjust = 0, vjust = 0, size = 8),
        axis.text.y       = element_text(size = 7),
        legend.key.height = unit(1.5, "cm"),
        panel.grid        = element_blank(),
        plot.title        = element_text(face = "bold"))
    
    ggsave(sprintf("P2_heatmap_lipidome_%s.pdf", mode), p_heat2,
           width = pw2, height = ph2, limitsize = FALSE)
    ggsave(sprintf("P2_heatmap_lipidome_%s.png", mode), p_heat2,
           width = pw2, height = ph2, limitsize = FALSE, dpi = 180)
    cat("  Part 2 heatmap saved\n")
    
    # Write summary table (rows = lipid_label, cols = solvent replicates)
    # Built from the (possibly category-filtered) mat_p2 to stay consistent
    # with the heatmaps.
    summary_p2 <- as.data.frame(mat_p2) %>%
      tibble::rownames_to_column("lipid_label") %>%
      arrange(lipid_label)
    write_results_xlsx(summary_p2,
                       sprintf("P2_lipidome_summary_%s.xlsx", mode))
    
    # ===========================================================================
    # PART 2 — HEATMAP (CATEGORY-GROUPED): same matrix, y-axis grouped by
    # LipidMaps Category, alphabetical category order, alphabetical lipid
    # order within each category.
    # ===========================================================================
    cat("Part 2 — Heatmap: sum-composition lipids grouped by category...\n\n")
    
    # label_category was built earlier (before the heatmap_categories filter)
    
    # Order rows: categories in alphabetical block order; WITHIN each category,
    # lipids ordered by complete-linkage clustering (falls back to alphabetical
    # for categories with <3 lipids or if a distance can't be computed).
    row_meta_p2 <- data.frame(lipid_label = rownames(mat_p2), stringsAsFactors = FALSE) %>%
      left_join(label_category, by = "lipid_label") %>%
      mutate(category = if_else(is.na(category), "Uncategorized", category))
    
    cluster_within <- function(labs) {
      labs <- sort(labs)
      if (length(labs) < 3) return(labs)
      sub <- scaled_p2[labs, , drop = FALSE]
      d   <- tryCatch(dist(sub), error = function(e) NULL)
      if (is.null(d) || anyNA(as.matrix(d)) || !all(is.finite(as.matrix(d))))
        return(labs)
      labs[hclust(d, method = "complete")$order]
    }
    
    row_ord_cat <- unlist(lapply(sort(unique(row_meta_p2$category)), function(ct) {
      cluster_within(row_meta_p2$lipid_label[row_meta_p2$category == ct])
    }), use.names = FALSE)
    
    # Reorder row_meta_p2 to match row_ord_cat so the category separators
    # (computed from row_meta_p2's category sequence) line up with the plot.
    row_meta_p2 <- row_meta_p2[match(row_ord_cat, row_meta_p2$lipid_label), ]
    
    long_p2_cat <- data.frame(
      lipid   = rep(rownames(scaled_p2), times = ncol(scaled_p2)),
      x_label = rep(colnames(scaled_p2), each  = nrow(scaled_p2)),
      value   = as.vector(scaled_p2)
    ) %>%
      left_join(row_meta_p2, by = c("lipid" = "lipid_label")) %>%
      mutate(
        lipid   = factor(lipid,   levels = rev(row_ord_cat)),
        x_label = factor(x_label, levels = rep_col_labels))
    
    # Horizontal separators between category blocks. The plotted y-axis uses
    # levels = rev(row_ord_cat), so position 1 (bottom) corresponds to the
    # LAST row of row_meta_p2 and position n (top) to the FIRST row.
    # Compute block boundaries in this bottom-to-top order.
    cat_seq_bottom_to_top <- rev(row_meta_p2$category)
    cat_order  <- unique(cat_seq_bottom_to_top)
    cat_counts <- table(factor(cat_seq_bottom_to_top, levels = cat_order))
    y_sep_cat  <- cumsum(as.numeric(cat_counts))
    y_sep_cat  <- y_sep_cat[-length(y_sep_cat)] + 0.5
    
    ph2_cat <- max(6, nrow(scaled_p2) * 0.3)
    pw2_cat <- length(rep_col_labels) * 0.6 + 4
    
    p_heat2_cat <- ggplot(long_p2_cat, aes(x = x_label, y = lipid, fill = value)) +
      geom_tile(colour = "white", linewidth = 0.25) +
      { lapply(x_sep_p2, function(xs)
        geom_vline(xintercept = xs, colour = "grey30", linewidth = 0.8)) } +
      { lapply(y_sep_cat, function(ys)
        geom_hline(yintercept = ys, colour = "grey30", linewidth = 0.8)) } +
      scale_fill_gradientn(colours = heatmap_colours, limits = c(-sl2, sl2),
                           na.value = "grey85",
                           name = if (pareto_scaling) "Pareto-scaled\nlog2" else "log2(sum abu + 1)") +
      scale_x_discrete(position = "top") +
      scale_y_discrete(expand = c(0, 0)) +
      labs(
        title    = sprintf("EV lipidome — sum-composition species by category × solvent replicates (%s mode)",
                           toupper(mode)),
        subtitle = paste0(
          "EV_LLE filtered vs blank_LLE + general_blank + blank_splash (FC ≥ ", fc_threshold, ")\n",
          if (pareto_scaling) "log2(sum abu) | Pareto scaled" else "log2(sum abu)",
          " | rows grouped by LipidMaps Category (A-Z), lipids clustered within category",
          " | LipidMaps matched (±", ppm_tolerance_lipidmaps, " ppm)"),
        x = "Solvent replicate", y = "Sum-composition lipid") +
      theme_minimal(base_size = 10) +
      theme(
        axis.text.x       = element_text(angle = 45, hjust = 0, vjust = 0, size = 8),
        axis.text.y       = element_text(size = 7),
        legend.key.height = unit(1.5, "cm"),
        panel.grid        = element_blank(),
        plot.title        = element_text(face = "bold"))
    
    ggsave(sprintf("P2_heatmap_lipidome_by_category_%s.pdf", mode), p_heat2_cat,
           width = pw2_cat, height = ph2_cat, limitsize = FALSE)
    ggsave(sprintf("P2_heatmap_lipidome_by_category_%s.png", mode), p_heat2_cat,
           width = pw2_cat, height = ph2_cat, limitsize = FALSE, dpi = 180)
    cat("  Part 2 category-grouped heatmap saved\n")
    
    # Write category assignment table for reference
    write_results_xlsx(row_meta_p2 %>% select(category, lipid_label),
                       sprintf("P2_lipidome_categories_%s.xlsx", mode))
    
    # ===========================================================================
    # PART 2 — BARPLOT: number of sum-composition lipids per LLE method
    # ===========================================================================
    # A lipid counts for a solvent if it was LipidMaps-matched in that solvent's
    # EV_LLE features (i.e. it survived the FC-vs-all-three-blanks filter there).
    # Restricted to the same lipid set as the heatmaps (heatmap_categories).
    cat("Part 2 — Barplot: lipid counts per LLE method...\n")
    
    kept_labels <- rownames(mat_p2)
    
    p2_counts <- p2_heatmap_data %>%
      filter(lipid_label %in% kept_labels) %>%
      distinct(solvent, lipid_label) %>%
      left_join(label_category, by = "lipid_label") %>%
      mutate(category = if_else(is.na(category), "Uncategorized", category))
    
    # Totals per solvent (used for the solvent-only variant)
    p2_counts_total <- p2_counts %>%
      count(solvent, name = "n_lipids") %>%
      tidyr::complete(solvent = solvent_names, fill = list(n_lipids = 0)) %>%
      mutate(solvent = factor(solvent, levels = solvent_names))
    
    # Per category x solvent, zero-filled so every category shows all four bars
    p2_counts_cat <- p2_counts %>%
      count(category, solvent, name = "n_lipids") %>%
      tidyr::complete(category = sort(unique(.$category)),
                      solvent  = solvent_names,
                      fill     = list(n_lipids = 0)) %>%
      mutate(solvent  = factor(solvent, levels = solvent_names),
             category = factor(category, levels = sort(unique(category))))
    
    if (barplot_by_category) {
      # x = LipidMaps category, one bar per solvent within each category
      p_bar2 <- ggplot(p2_counts_cat,
                       aes(x = category, y = n_lipids, fill = solvent)) +
        geom_col(position = position_dodge(width = 0.8), width = 0.7,
                 colour = "grey20", linewidth = 0.2) +
        geom_text(aes(label = n_lipids),
                  position = position_dodge(width = 0.8),
                  vjust = -0.35, size = 2.8) +
        scale_fill_manual(values = solvent_colours) +
        labs(x = "LipidMaps category", fill = "LLE method")
      bar_ymax <- max(p2_counts_cat$n_lipids, na.rm = TRUE)
      bar_w    <- max(8, nlevels(p2_counts_cat$category) * n_solvents * 0.5 + 3)
    } else {
      # x = solvent, one bar per solvent (overall totals)
      p_bar2 <- ggplot(p2_counts_total,
                       aes(x = solvent, y = n_lipids, fill = solvent)) +
        geom_col(width = 0.65, colour = "grey20", linewidth = 0.2,
                 show.legend = FALSE) +
        geom_text(aes(label = n_lipids), vjust = -0.4, size = 3.5,
                  fontface = "bold") +
        scale_fill_manual(values = solvent_colours) +
        labs(x = "LLE method (solvent)")
      bar_ymax <- max(p2_counts_total$n_lipids, na.rm = TRUE)
      bar_w    <- max(6, n_solvents * 1.8)
    }
    
    p_bar2 <- p_bar2 +
      scale_y_continuous(expand = expansion(mult = c(0, 0.10))) +
      expand_limits(y = bar_ymax * 1.08) +
      labs(
        title    = sprintf("EV lipids identified per LLE method (%s mode)", toupper(mode)),
        subtitle = paste0(
          "Distinct sum-composition species | EV_LLE filtered vs blank_LLE + general_blank + blank_splash (FC ≥ ",
          fc_threshold, ")\n",
          "LipidMaps matched (±", ppm_tolerance_lipidmaps, " ppm)",
          if (!is.null(heatmap_categories) && !identical(heatmap_categories, "all"))
            paste0(" | categories: ", paste(heatmap_categories, collapse = ", ")) else ""),
        y = "Number of lipids (sum composition)") +
      theme_minimal(base_size = 12) +
      theme(
        axis.text.x        = element_text(angle = 30, hjust = 1, size = 9),
        panel.grid.major.x = element_blank(),
        plot.title         = element_text(face = "bold"),
        legend.position    = "right")
    
    ggsave(sprintf("P2_barplot_lipid_counts_%s.pdf", mode), p_bar2,
           width = bar_w, height = 6, limitsize = FALSE)
    ggsave(sprintf("P2_barplot_lipid_counts_%s.png", mode), p_bar2,
           width = bar_w, height = 6, limitsize = FALSE, dpi = 200)
    cat("  Part 2 barplot saved\n")
    
    # Counts table: rows = category (+ Total), cols = solvents
    counts_wide <- p2_counts_cat %>%
      mutate(category = as.character(category)) %>%
      tidyr::pivot_wider(names_from = solvent, values_from = n_lipids,
                         values_fill = 0, names_expand = TRUE) %>%
      arrange(category)
    total_row <- p2_counts_total %>%
      tidyr::pivot_wider(names_from = solvent, values_from = n_lipids,
                         values_fill = 0, names_expand = TRUE) %>%
      mutate(category = "Total", .before = 1)
    write_results_xlsx(bind_rows(counts_wide, total_row),
                       sprintf("P2_lipid_counts_%s.xlsx", mode))
    
  } # end nrow(mat_p2) > 0
  
} else {
  cat("  WARNING: No LipidMaps matches found across any solvent — heatmap skipped.\n")
}

# =============================================================================
# PART 3: LLE RECOVERY — EV_LLE vs blank_splash, per internal standard
# =============================================================================
cat("\n========================================\n")
cat("PART 3: LLE recovery (IS)\n")
cat("========================================\n\n")

# Recovery(%) = 100 * EV_LLE abundance / mean(blank_splash abundance)
#
# blank_splash = internal standards spiked into a blank WITHOUT going through
# the extraction, so it serves as the 100% (un-extracted) reference. EV_LLE
# = the same standards carried through the LLE in the EV sample, so the ratio
# is the fraction of each standard surviving extraction with that solvent.
#
# NOTE: computed from the RAW abundances (IS-matched only), NOT from the Part 1
# filtered tables. The Part 1 missingness/abundance/FC filters would silently
# drop poorly-recovered standards — exactly the signal a recovery plot must show.

p3_cols <- c(EV_LLE_cols, blank_splash_cols)
p3_raw  <- raw_all %>% select(mz, all_of(p3_cols))
p3_is   <- match_db(p3_raw, is_ref, "is_mz", ppm_tol = ppm_tolerance)

if (is.null(p3_is) || nrow(p3_is) == 0) {
  cat("  WARNING: no IS matched in raw data — recovery plot skipped.\n\n")
} else {
  
  # If several m/z features match the same IS, sum them into one value per IS
  p3_is <- p3_is %>%
    group_by(is_name) %>%
    summarise(across(all_of(p3_cols), ~ sum(.x, na.rm = TRUE)), .groups = "drop")
  cat(sprintf("  IS matched in raw data: %d standards\n", nrow(p3_is)))
  
  # --- Denominator: mean blank_splash abundance per IS (the 100% reference) ---
  splash_ref <- p3_is %>%
    mutate(splash_mean = rowMeans(across(all_of(blank_splash_cols)), na.rm = TRUE)) %>%
    select(is_name, splash_mean)
  
  n_before_ref <- nrow(splash_ref)
  splash_ref <- splash_ref %>%
    filter(!is.na(splash_mean), splash_mean > recovery_min_splash_abundance)
  cat(sprintf("  Usable splash reference: %d / %d standards (min splash abu = %s)\n",
              nrow(splash_ref), n_before_ref,
              format(recovery_min_splash_abundance, big.mark = ",")))
  
  if (nrow(splash_ref) == 0) {
    cat("  WARNING: no IS passed the splash-abundance filter — recovery plot skipped.\n\n")
  } else {
    
    # --- Numerator: per-replicate EV_LLE abundance, long by solvent x rep ---
    p3_long <- bind_rows(lapply(solvent_names, function(sv) {
      sv_cols <- EV_LLE_by_sv[[sv]]
      p3_is %>%
        select(is_name, all_of(sv_cols)) %>%
        pivot_longer(-is_name, names_to = "rep", values_to = "abundance") %>%
        mutate(solvent = sv)
    })) %>%
      inner_join(splash_ref, by = "is_name") %>%
      mutate(
        abundance    = as.numeric(abundance),
        recovery_pct = 100 * abundance / splash_mean)
    
    # --- Summarise: mean recovery per IS x solvent, with replicate spread ---
    p3_summary <- p3_long %>%
      group_by(is_name, solvent) %>%
      summarise(
        n_reps        = sum(!is.na(recovery_pct)),
        mean_recovery = mean(recovery_pct, na.rm = TRUE),
        sd_recovery   = sd(recovery_pct,   na.rm = TRUE),
        .groups = "drop") %>%
      mutate(
        sd_recovery  = if_else(is.na(sd_recovery), 0, sd_recovery),
        sem_recovery = if_else(n_reps > 1, sd_recovery / sqrt(n_reps), 0),
        err  = if (recovery_errorbar == "sem") sem_recovery else sd_recovery,
        ymin = pmax(mean_recovery - err, 0),   # recovery cannot be negative
        ymax = mean_recovery + err,
        solvent = factor(solvent, levels = solvent_names),
        is_name = factor(is_name, levels = sort(unique(as.character(is_name)))))
    
    cat(sprintf("  Recovery computed for %d IS x %d solvents\n",
                nlevels(p3_summary$is_name), n_solvents))
    cat(sprintf("  Error bars: %s\n", toupper(recovery_errorbar)))
    
    # --- Barplot: x = IS lipid, one bar per solvent, error bar on each bar ---
    p_bar3 <- ggplot(p3_summary,
                     aes(x = is_name, y = mean_recovery, fill = solvent)) +
      geom_col(position = position_dodge(width = 0.8), width = 0.7,
               colour = "grey20", linewidth = 0.2) +
      geom_errorbar(aes(ymin = ymin, ymax = ymax),
                    position = position_dodge(width = 0.8),
                    width = 0.25, linewidth = 0.35, colour = "grey20") +
      scale_fill_manual(values = solvent_colours) +
      scale_y_continuous(expand = expansion(mult = c(0, 0.08))) +
      labs(
        title    = sprintf("LLE recovery of internal standards (%s mode)", toupper(mode)),
        subtitle = paste0(
          "Recovery = 100 x EV_LLE / mean(blank_splash), per standard | ",
          "raw IS-matched abundances (\u00b1", ppm_tolerance, " ppm)\n",
          "Bars = mean of ", n_replicates, " EV_LLE replicates | error bars = ",
          if (recovery_errorbar == "sem") "SEM" else "SD", " across replicates"),
        x = "Internal standard", y = "Recovery (%)", fill = "LLE method") +
      theme_minimal(base_size = 12) +
      theme(
        axis.text.x        = element_text(angle = 45, hjust = 1, size = 8),
        panel.grid.major.x = element_blank(),
        plot.title         = element_text(face = "bold"),
        legend.position    = "right")
    
    if (recovery_show_100_line)
      p_bar3 <- p_bar3 +
      geom_hline(yintercept = 100, linetype = "dashed",
                 colour = "grey40", linewidth = 0.4)
    
    pw3 <- max(8, nlevels(p3_summary$is_name) * n_solvents * 0.22 + 4)
    ggsave(sprintf("P3_barplot_recovery_IS_%s.pdf", mode), p_bar3,
           width = pw3, height = 6.5, limitsize = FALSE)
    ggsave(sprintf("P3_barplot_recovery_IS_%s.png", mode), p_bar3,
           width = pw3, height = 6.5, limitsize = FALSE, dpi = 200)
    cat("  Recovery barplot saved\n")
    
    # --- Tables ---
    write_results_xlsx(
      p3_summary %>%
        select(is_name, solvent, n_reps, mean_recovery, sd_recovery, sem_recovery) %>%
        mutate(across(c(mean_recovery, sd_recovery, sem_recovery), ~ round(.x, 2))) %>%
        arrange(is_name, solvent),
      sprintf("P3_recovery_summary_%s.xlsx", mode))
    
    # Per-replicate detail (abundance + splash reference + recovery)
    write_results_xlsx(
      p3_long %>%
        mutate(recovery_pct = round(recovery_pct, 2)) %>%
        arrange(is_name, solvent, rep),
      sprintf("P3_recovery_per_replicate_%s.xlsx", mode))
    
    cat("\n")
  }
}

cat("\n=== All outputs complete ===\n")
cat("Part 1 outputs: P1_*\n")
cat("Part 2 outputs: P2_*\n")
cat("Part 3 outputs: P3_*\n")
