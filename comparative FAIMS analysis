  build_IS_heatmap_data <- function(scope, faims_mode) {
    samples_to_use <- if (scope == "all_samples") is_signal_samples else scope
    parts <- list(); col_labels <- character(0); sep_after <- numeric(0); col_count <- 0
    
    for (cond in c("DI", if (has_FAIMSoff) "FAIMSoff", "FAIMS")) {
      for (s in samples_to_use) {
        
        if (cond == "DI") {
          sub_mat  <- DI_IS_mat[, grep(paste0("^", s, "_rep"), colnames(DI_IS_mat)), drop = FALSE]
          new_labs <- paste0(if (scope == "all_samples") paste0(s, "_DI_") else "DI_",
                             "rep", seq_len(n_replicates))
          parts <- c(parts, list(sub_mat)); col_labels <- c(col_labels, new_labs)
          col_count <- col_count + n_replicates
          
        } else if (cond == "FAIMSoff") {
          sub_mat  <- FO_IS_mat[, grep(paste0("^", s, "_rep"), colnames(FO_IS_mat)), drop = FALSE]
          new_labs <- paste0(if (scope == "all_samples") paste0(s, "_FAIMSoff_") else "FAIMSoff_",
                             "rep", seq_len(n_replicates))
          parts <- c(parts, list(sub_mat)); col_labels <- c(col_labels, new_labs)
          col_count <- col_count + n_replicates
          
        } else {  # FAIMS
          if (faims_mode == "bestCV") {
            sub_mat  <- FAIMS_IS_bestcv_mat[,
                                            grep(paste0("^", s, "_FAIMS_bestCV_rep"), colnames(FAIMS_IS_bestcv_mat)),
                                            drop = FALSE]
            new_labs <- paste0(if (scope == "all_samples") paste0(s, "_FAIMS_bestCV_") else "FAIMS_bestCV_",
                               "rep", seq_len(n_replicates))
            parts <- c(parts, list(sub_mat)); col_labels <- c(col_labels, new_labs)
            col_count <- col_count + n_replicates
            sep_after <- c(sep_after, col_count)
            next
            
          } else {  # allCV
            for (cv in cv_labels) {
              cv_cols <- grep(paste0("^", s, "_FAIMS_", cv, "_rep"),
                              colnames(FAIMS_IS_allcv_mat), value = TRUE)
              sub_mat <- if (length(cv_cols) > 0)
                FAIMS_IS_allcv_mat[, cv_cols, drop = FALSE]
              else
                matrix(NA_real_, nrow = n_is, ncol = n_replicates,
                       dimnames = list(all_is_labels,
                                       paste0(s, "_FAIMS_", cv, "_rep", seq_len(n_replicates))))
              cv_labs <- paste0(
                if (scope == "all_samples") paste0(s, "_FAIMS_", cv, "_") else paste0("FAIMS_", cv, "_"),
                "rep", seq_len(n_replicates))
              parts <- c(parts, list(sub_mat)); col_labels <- c(col_labels, cv_labs)
              col_count <- col_count + n_replicates
            }
            sep_after <- c(sep_after, col_count)
            next
          }
        }
      }
      if (cond != "FAIMS") sep_after <- c(sep_after, col_count)
    }
    
    mat_out <- do.call(cbind, parts)
    rownames(mat_out) <- all_is_labels
    sep_after <- sep_after[sep_after < ncol(mat_out)]
    list(mat = mat_out, col_labels = col_labels, sep_after = sep_after)
  }
  
