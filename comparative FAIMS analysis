# ---------------------------------------------------------------------------
# IS-specific matching functions
# match_IS()    : matches filtered data against the simple IS reference
#                 (one m/z per IS, no adduct logic)
# run_IS_di_pipeline() : full filter + match pipeline for DI/FAIMSoff IS
# run_IS_faims_pipeline() : full filter + match pipeline for FAIMS IS
# ---------------------------------------------------------------------------

match_IS <- function(filt_df, IS_ref, ppm_thresh, source_tag) {
  # Loop over IS entries (small: ~10 compounds), vectorise ppm calculation
  # across all filt_df rows at once — far faster than looping over filt rows.
  result <- lapply(seq_len(nrow(IS_ref)), function(h) {
    theo       <- IS_ref$IS_mz[h]
    ppm_errors <- ((filt_df$mz - theo) / theo) * 1e6
    idx        <- which(abs(ppm_errors) <= ppm_thresh & !is.na(ppm_errors))
    if (length(idx) == 0L) return(NULL)
    cbind(
      data.frame(
        is_label            = IS_ref$IS_name[h],
        sum_composition_syn = IS_ref$IS_name[h],
        common_name         = IS_ref$IS_name[h],
        systematic_name     = NA_character_,
        lmsd_id             = NA_character_,
        theoretical_mz      = theo,
        ppm_error           = round(ppm_errors[idx], 4),
        source              = source_tag,
        stringsAsFactors    = FALSE
      ),
      filt_df[idx, , drop = FALSE]
    )
  })
  bind_rows(result)
}

run_IS_di_pipeline <- function(raw_df,
                               sample_cols_list,
                               signal_samples,
                               blank_samples,
                               abundance_threshold,
                               fold_change_threshold,
                               max_zeros_allowed,
                               cov_green, cov_yellow,
                               cov_filter_remove,
                               IS_ref, ppm_threshold,
                               source_tag,
                               file_filtered, file_matched) {
  signal_cols_list <- sample_cols_list[signal_samples]
  blank_groups     <- sample_cols_list[blank_samples]
  n_sig            <- length(signal_samples)
  
  miss_ok <- sapply(signal_cols_list, function(cols)
    count_zeros(raw_df, cols) < max_zeros_allowed)
  if (is.null(dim(miss_ok))) miss_ok <- matrix(miss_ok, ncol = n_sig)
  filt <- raw_df[rowSums(miss_ok) >= 1, ]
  cat(sprintf("%s — after missingness filter: %d of %d retained\n",
              source_tag, nrow(filt), nrow(raw_df)))
  
  abun_ok <- sapply(signal_cols_list, function(cols)
    rowMeans(filt[, cols, drop = FALSE], na.rm = TRUE) >= abundance_threshold)
  if (is.null(dim(abun_ok))) abun_ok <- matrix(abun_ok, ncol = n_sig)
  filt <- filt[rowSums(abun_ok) >= 1, ]
  cat(sprintf("%s — after abundance filter: %d retained\n", source_tag, nrow(filt)))
  
  fc_ok <- sapply(signal_cols_list, function(sig_cols) {
    mean_sig <- rowMeans(filt[, sig_cols, drop = FALSE], na.rm = TRUE)
    max_bl   <- max_blank_mean(filt, blank_groups)
    ((mean_sig + 1) / (max_bl + 1)) >= fold_change_threshold
  })
  if (is.null(dim(fc_ok))) fc_ok <- matrix(fc_ok, ncol = n_sig)
  filt <- filt[rowSums(fc_ok) >= 1, ]
  cat(sprintf("%s — after fold-change filter: %d retained\n", source_tag, nrow(filt)))
  
  cov_col_names <- character(n_sig)
  for (s in signal_samples) {
    cols    <- sample_cols_list[[s]]
    mean_s  <- rowMeans(filt[, cols, drop = FALSE], na.rm = TRUE)
    sd_s    <- apply(   filt[, cols, drop = FALSE], 1, sd, na.rm = TRUE)
    cov_col <- paste0("CoV_pct_", s)
    cov_col_names[match(s, signal_samples)] <- cov_col
    filt[[paste0("mean_", s)]] <- mean_s
    filt[[cov_col]]            <- (sd_s / mean_s) * 100
  }
  for (s in signal_samples)
    print_cov_summary(filt[[paste0("CoV_pct_", s)]],
                      paste(source_tag, s), cov_green, cov_yellow)
  
  if (cov_filter_remove) {
    n_before <- nrow(filt)
    cov_fail <- rowSums(sapply(cov_col_names, function(cn)
      !is.na(filt[[cn]]) & filt[[cn]] >= cov_green)) == n_sig
    filt <- filt[!cov_fail, ]
    cat(sprintf("%s — after CoV filter: %d of %d retained\n",
                source_tag, nrow(filt), n_before))
  }
  cat("\n")
  
  cov_meta <- setNames(
    lapply(cov_col_names, function(cn) list(green = cov_green, yellow = cov_yellow)),
    cov_col_names)
  
  # Write filtered file: mz + mean + CoV summary only (drop raw replicates)
  filt_summary_cols <- c("mz",
                         grep("^mean_", colnames(filt), value = TRUE),
                         cov_col_names)
  filt_summary <- filt[, intersect(filt_summary_cols, colnames(filt)), drop = FALSE]
  write_xlsx_cov(filt_summary, file_filtered, cov_meta)
  
  matched_raw <- match_IS(filt, IS_ref, ppm_threshold, source_tag)
  
  # Write matched file: IS metadata + mean + CoV only (drop raw replicate columns)
  meta_cols   <- c("is_label", "sum_composition_syn", "common_name",
                   "theoretical_mz", "ppm_error", "mz", "source")
  mean_cols   <- grep("^mean_", colnames(matched_raw), value = TRUE)
  cov_cols_mr <- grep("^CoV_pct_", colnames(matched_raw), value = TRUE)
  keep_cols   <- intersect(c(meta_cols, mean_cols, cov_cols_mr), colnames(matched_raw))
  matched_out <- matched_raw[, keep_cols, drop = FALSE]
  cov_meta_mr <- setNames(
    lapply(cov_cols_mr, function(cn) list(green = cov_green, yellow = cov_yellow)),
    cov_cols_mr)
  cat(sprintf("%s — IS-matched rows: %d\n\n", source_tag, nrow(matched_out)))
  write_xlsx_cov(matched_out, file_matched, cov_meta_mr)
  
  list(filt = filt, matched = matched_raw)
}

run_IS_faims_pipeline <- function(raw_df,
                                  signal_by_CV,
                                  blank_by_CV,
                                  signal_samples,
                                  abundance_threshold,
                                  fold_change_threshold,
                                  max_zeros_allowed,
                                  cov_green, cov_yellow,
                                  cov_filter_remove,
                                  IS_ref, ppm_threshold,
                                  source_tag,
                                  file_filtered, file_matched) {
  n_sig  <- length(signal_samples)
  n_cond <- length(cv_labels)
  
  miss_ok <- sapply(signal_by_CV, function(sig_cv_list) {
    cv_pass <- sapply(sig_cv_list, function(cols)
      count_zeros(raw_df, cols) < max_zeros_allowed)
    if (is.null(dim(cv_pass))) cv_pass <- matrix(cv_pass, ncol = n_cond)
    rowSums(cv_pass) >= 1
  })
  if (is.null(dim(miss_ok))) miss_ok <- matrix(miss_ok, ncol = n_sig)
  filt <- raw_df[rowSums(miss_ok) >= 1, ]
  cat(sprintf("%s — after missingness filter: %d of %d retained\n",
              source_tag, nrow(filt), nrow(raw_df)))
  
  abun_ok <- sapply(signal_by_CV, function(sig_cv_list) {
    cv_pass <- sapply(sig_cv_list, function(cols)
      rowMeans(filt[, cols, drop = FALSE], na.rm = TRUE) >= abundance_threshold)
    if (is.null(dim(cv_pass))) cv_pass <- matrix(cv_pass, ncol = n_cond)
    rowSums(cv_pass) >= 1
  })
  if (is.null(dim(abun_ok))) abun_ok <- matrix(abun_ok, ncol = n_sig)
  filt <- filt[rowSums(abun_ok) >= 1, ]
  cat(sprintf("%s — after abundance filter: %d retained\n", source_tag, nrow(filt)))
  
  fc_ok <- sapply(signal_by_CV, function(sig_cv_list) {
    cv_pass <- sapply(seq_along(cv_labels), function(i) {
      mean_sig       <- rowMeans(filt[, sig_cv_list[[i]], drop = FALSE], na.rm = TRUE)
      blank_groups_i <- lapply(blank_by_CV, `[[`, i)
      max_bl         <- max_blank_mean(filt, blank_groups_i)
      ((mean_sig + 1) / (max_bl + 1)) >= fold_change_threshold
    })
    if (is.null(dim(cv_pass))) cv_pass <- matrix(cv_pass, ncol = n_cond)
    rowSums(cv_pass) >= 1
  })
  if (is.null(dim(fc_ok))) fc_ok <- matrix(fc_ok, ncol = n_sig)
  filt <- filt[rowSums(fc_ok) >= 1, ]
  cat(sprintf("%s — after fold-change filter: %d retained\n\n", source_tag, nrow(filt)))
  
  cov_cols_out  <- setNames(vector("list", n_sig), signal_samples)
  faims_cv_pass <- setNames(vector("list", n_sig), signal_samples)
  
  for (s in signal_samples) {
    sig_cv_list     <- signal_by_CV[[s]]
    cov_col_names_s <- character(n_cond)
    cv_pass_s       <- matrix(FALSE, nrow = nrow(filt), ncol = n_cond)
    for (i in seq_along(cv_labels)) {
      cols     <- sig_cv_list[[i]]
      mean_s   <- rowMeans(filt[, cols, drop = FALSE], na.rm = TRUE)
      sd_s     <- apply(   filt[, cols, drop = FALSE], 1, sd, na.rm = TRUE)
      cov_col  <- paste0("CoV_pct_", s, "_", cv_labels[i])
      cov_col_names_s[i] <- cov_col
      filt[[paste0("mean_", s, "_", cv_labels[i])]] <- mean_s
      filt[[cov_col]] <- (sd_s / mean_s) * 100
      blank_groups_i <- lapply(blank_by_CV, `[[`, i)
      max_bl_i       <- max_blank_mean(filt, blank_groups_i)
      cov_pass_i     <- if (cov_filter_remove)
        (filt[[cov_col]] < cov_green) else rep(TRUE, nrow(filt))
      cv_pass_s[, i] <- (mean_s >= abundance_threshold) &
        (((mean_s + 1) / (max_bl_i + 1)) >= fold_change_threshold) &
        cov_pass_i
    }
    cov_cols_out[[s]]  <- cov_col_names_s
    faims_cv_pass[[s]] <- cv_pass_s
  }
  
  all_cov_cols <- unlist(cov_cols_out)
  if (cov_filter_remove) {
    n_before <- nrow(filt)
    cov_fail <- rowSums(sapply(all_cov_cols, function(cn)
      !is.na(filt[[cn]]) & filt[[cn]] >= cov_green)) == length(all_cov_cols)
    filt <- filt[!cov_fail, ]
    for (s in signal_samples)
      faims_cv_pass[[s]] <- faims_cv_pass[[s]][!cov_fail, ]
    cat(sprintf("%s — after CoV filter: %d of %d retained\n", source_tag, nrow(filt), n_before))
  }
  cat("\n")
  
  cov_meta <- setNames(
    lapply(all_cov_cols, function(cn) list(green = cov_green, yellow = cov_yellow)),
    all_cov_cols)
  
  # Write filtered file: keep only mz + mean + CoV columns (not raw replicates).
  # The raw FAIMS IS filtered table has 130+ replicate columns — writing and
  # CoV-colouring all of them row-by-row is the primary performance bottleneck.
  filt_summary_cols <- c("mz",
                         grep("^mean_", colnames(filt), value = TRUE),
                         all_cov_cols)
  filt_summary <- filt[, intersect(filt_summary_cols, colnames(filt)), drop = FALSE]
  write_xlsx_cov(filt_summary, file_filtered, cov_meta)
  
  matched_raw <- match_IS(filt, IS_ref, ppm_threshold, source_tag)
  
  if (nrow(matched_raw) > 0) {
    # Build a lookup: mz value -> first row index in filt (vectorised, no loop)
    faims_filt_mz  <- filt$mz
    mz_to_filt_idx <- match(matched_raw$mz, faims_filt_mz)  # NA if not found
    
    # For each matched row, union passing CVs across all signal samples
    # using pre-indexed faims_cv_pass matrices — no per-row which() calls
    passing_cvs_col <- vapply(seq_len(nrow(matched_raw)), function(i) {
      fi <- mz_to_filt_idx[i]
      if (is.na(fi)) return(NA_character_)
      cvs_pass <- logical(length(cv_labels))
      for (s in signal_samples)
        cvs_pass <- cvs_pass | faims_cv_pass[[s]][fi, ]
      if (!any(cvs_pass)) NA_character_ else
        paste(sort(cv_labels[cvs_pass]), collapse = ", ")
    }, character(1))
    matched_raw$passing_CVs <- passing_cvs_col
    matched_raw <- matched_raw[!is.na(matched_raw$passing_CVs), ]
  } else {
    matched_raw$passing_CVs <- character(0)
  }
  
  # Write matched file: keep IS metadata + passing_CVs + mean + CoV columns only.
  # Raw replicate columns from filt are attached by match_IS via cbind — drop them.
  meta_cols   <- c("is_label", "sum_composition_syn", "common_name",
                   "theoretical_mz", "ppm_error", "mz", "source", "passing_CVs")
  mean_cols   <- grep("^mean_", colnames(matched_raw), value = TRUE)
  cov_cols_mr <- grep("^CoV_pct_", colnames(matched_raw), value = TRUE)
  keep_cols   <- intersect(c(meta_cols, mean_cols, cov_cols_mr), colnames(matched_raw))
  matched_out <- matched_raw[, keep_cols, drop = FALSE]
  cov_meta_mr <- setNames(
    lapply(cov_cols_mr, function(cn) list(green = cov_green, yellow = cov_yellow)),
    cov_cols_mr)
  cat(sprintf("%s — IS-matched rows: %d\n\n", source_tag, nrow(matched_out)))
  write_xlsx_cov(matched_out, file_matched, cov_meta_mr)
  
  list(filt = filt, matched = matched_raw,
       cov_cols = cov_cols_out, faims_cv_pass = faims_cv_pass)
}

