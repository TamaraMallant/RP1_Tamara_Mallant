  extract_rep_matrix <- function(matched_df, sample_names, sample_cols_list,
                                 all_labels, n_rep) {
    col_names <- unlist(lapply(sample_names, function(s)
      paste0(s, "_rep", seq_len(n_rep))))
    mat <- matrix(NA_real_, nrow = length(all_labels), ncol = length(col_names),
                  dimnames = list(all_labels, col_names))
    if (nrow(matched_df) == 0) return(mat)
    for (s in sample_names) {
      src_cols <- intersect(sample_cols_list[[s]], colnames(matched_df))
      out_cols <- paste0(s, "_rep", seq_len(n_rep))
      for (lab in all_labels) {
        rows <- matched_df[matched_df$is_label == lab, , drop = FALSE]
        if (nrow(rows) == 0) next
        mat[lab, out_cols] <- as.numeric(colSums(rows[, src_cols, drop = FALSE], na.rm = TRUE))
      }
    }
    mat
  }
  
