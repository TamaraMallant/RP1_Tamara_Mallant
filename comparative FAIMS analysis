combined <- lapply(all_keys, function(key) {
  di_row    <- DI_uniq[DI_uniq$group_key == key, ]
  fo_row    <- FAIMSoff_uniq[FAIMSoff_uniq$group_key == key, ]
  faims_row <- FAIMS_uniq[FAIMS_uniq$group_key == key, ]
  
  in_DI       <- nrow(di_row)    > 0
  in_FAIMSoff <- nrow(fo_row)    > 0
  in_FAIMS    <- nrow(faims_row) > 0
  
  src_tags  <- c(if (in_DI) "DI", if (in_FAIMSoff) "FAIMSoff", if (in_FAIMS) "FAIMS")
  detection <- if (length(src_tags) > 1) paste(src_tags, collapse = " + ") else
    paste(src_tags, "only")
  
  src <- if (in_DI) di_row else if (in_FAIMSoff) fo_row else faims_row
  
  faims_cvs <- NA_character_
  if (in_FAIMS) {
    cvs <- unique(unlist(strsplit(
      faims_row$passing_CVs[!is.na(faims_row$passing_CVs)], ",\\s*")))
    faims_cvs <- if (length(cvs) > 0) paste(sort(cvs), collapse = ", ") else NA_character_
  }
  
  mz_DI        <- if (in_DI)       di_row$mz[1]          else NA_real_
  mz_FAIMSoff  <- if (in_FAIMSoff) fo_row$mz[1]          else NA_real_
  mz_FAIMS     <- if (in_FAIMS)    faims_row$mz[1]        else NA_real_
  ppm_DI       <- if (in_DI)       di_row$ppm_error[1]   else NA_real_
  ppm_FAIMSoff <- if (in_FAIMSoff) fo_row$ppm_error[1]   else NA_real_
  ppm_FAIMS    <- if (in_FAIMS)    faims_row$ppm_error[1] else NA_real_
  
  di_rep_list  <- list()
  di_mean_list <- list()
  for (s in signal_samples) {
    cols <- DI_sample_cols[[s]]
    vals <- if (in_DI)
      as.numeric(di_row[1, intersect(cols, colnames(di_row))])
    else rep(NA_real_, n_replicates)
    di_rep_list  <- c(di_rep_list,
                      setNames(as.list(vals), paste0(s, "_DI_rep", seq_len(n_replicates))))
    di_mean_list <- c(di_mean_list,
                      setNames(list(round(mean(vals, na.rm = TRUE), 1)),
                               paste0("mean_", s, "_DI")))
  }
  
  fo_rep_list  <- list()
  fo_mean_list <- list()
  if (has_FAIMSoff) {
    for (s in signal_samples) {
      cols <- FAIMSoff_sample_cols[[s]]
      vals <- if (in_FAIMSoff)
        as.numeric(fo_row[1, intersect(cols, colnames(fo_row))])
      else rep(NA_real_, n_replicates)
      fo_rep_list  <- c(fo_rep_list,
                        setNames(as.list(vals),
                                 paste0(s, "_FAIMSoff_rep", seq_len(n_replicates))))
      fo_mean_list <- c(fo_mean_list,
                        setNames(list(round(mean(vals, na.rm = TRUE), 1)),
                                 paste0("mean_", s, "_FAIMSoff")))
    }
  }
  
  faims_rep_list  <- list()
  faims_mean_list <- list()
  for (s in signal_samples) {
    sig_cv_list <- signal_by_CV_list[[s]]
    for (i in seq_along(cv_labels)) {
      cols <- sig_cv_list[[i]]
      vals <- if (in_FAIMS)
        as.numeric(faims_row[1, intersect(cols, colnames(faims_row))])
      else rep(NA_real_, n_replicates)
      faims_rep_list  <- c(faims_rep_list,
                           setNames(as.list(vals),
                                    paste0(s, "_FAIMS_", cv_labels[i], "_rep", seq_len(n_replicates))))
      faims_mean_list <- c(faims_mean_list,
                           setNames(list(round(mean(vals, na.rm = TRUE), 1)),
                                    paste0("mean_", s, "_FAIMS_", cv_labels[i])))
    }
  }
  
  row_out <- c(
    list(
      sum_composition_syn = src$sum_composition_syn[1],
      lmsd_ids            = src$lmsd_id[1],
      common_names        = src$common_name[1],
      systematic_names    = src$systematic_name[1],
      category            = src$category[1],
      main_class          = src$main_class[1],
      sub_class           = src$sub_class[1],
      kegg_ids            = src$kegg_id[1],
      adduct              = src$adduct[1],
      theoretical_mz      = src$theoretical_mz[1],
      exact_mass          = lmsd$`Exact mass`[match(
        strsplit(src$lmsd_id[1], "; ")[[1]][1], lmsd$`LipidMaps ID`)][1],
      detection           = detection,
      FAIMS_CVs           = faims_cvs,
      mz_DI               = mz_DI,
      ppm_DI              = ppm_DI,
      mz_FAIMSoff         = mz_FAIMSoff,
      ppm_FAIMSoff        = ppm_FAIMSoff,
      mz_FAIMS            = mz_FAIMS,
      ppm_FAIMS           = ppm_FAIMS
    ),
    di_rep_list, fo_rep_list, faims_rep_list,
    di_mean_list, fo_mean_list, faims_mean_list
  )
  as.data.frame(row_out, stringsAsFactors = FALSE)
})

