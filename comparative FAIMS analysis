  pareto_scale_mat <- function(mat) {
    out <- t(apply(mat, 1, function(x) {
      mu  <- mean(x, na.rm = TRUE); sig <- sd(x, na.rm = TRUE)
      if (is.na(mu) || is.na(sig) || sig == 0) return(x - mu)
      (x - mu) / sqrt(sig)
    }))
    colnames(out) <- colnames(mat); out
  }
  
  draw_IS_heatmap_sep <- function(mat, col_labels, sep_after,
                                  title_str, subtitle_str, file_base) {
    if (all(is.na(mat))) { cat("  No data — heatmap skipped.\n"); return() }
    mat_plot <- mat; mat_plot[is.na(mat_plot)] <- 0
    log2_mat <- log2(mat_plot + 1); log2_mat[!is.finite(log2_mat)] <- 0
    scaled   <- pareto_scale_mat(log2_mat)
    scaled[is.na(mat)] <- NA_real_
    
    sl <- max(abs(range(scaled, na.rm = TRUE)), na.rm = TRUE)
    if (!is.finite(sl) || sl == 0) sl <- 1
    ph <- max(5, nrow(scaled) * 0.38)
    pw <- ncol(scaled) * 0.48 + 4
    
    long_df <- data.frame(
      lipid   = rep(rownames(scaled), times = ncol(scaled)),
      x_label = rep(col_labels,       each  = nrow(scaled)),
      value   = as.vector(scaled)
    ) %>%
      mutate(lipid   = factor(lipid,   levels = rev(rownames(scaled))),
             x_label = factor(x_label, levels = col_labels))
    
    p <- ggplot(long_df, aes(x = x_label, y = lipid, fill = value)) +
      geom_tile(colour = "white", linewidth = 0.3) +
      { lapply(sep_after, function(xs)
