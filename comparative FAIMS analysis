    sum_comp <- as.character(sum_comp); common_name <- as.character(common_name)
    systematic_name <- as.character(systematic_name); ids <- as.character(ids)
    is_blank <- function(x) is.na(x) | trimws(x) == ""
    label <- sum_comp
    use <- is_blank(label); label[use] <- common_name[use]
    use <- is_blank(label); label[use] <- systematic_name[use]
    use <- is_blank(label); label[use] <- ids[use]
    label
  }
  
  all_cols <- colnames(combined_df)
  
  sample_blocks <- lapply(signal_samples, function(s) {
    di_cols <- grep(paste0("^", s, "_DI_rep[0-9]+$"), all_cols, value = TRUE)
    di_cols <- di_cols[order(as.integer(sub(".*_rep", "", di_cols)))]
    fo_cols <- grep(paste0("^", s, "_FAIMSoff_rep[0-9]+$"), all_cols, value = TRUE)
    fo_cols <- fo_cols[order(as.integer(sub(".*_rep", "", fo_cols)))]
    faims_cols_all <- grep(paste0("^", s, "_FAIMS_.*_rep[0-9]+$"), all_cols, value = TRUE)
    cv_part <- sub(paste0("^", s, "_FAIMS_(.*)_rep[0-9]+$"), "\\1", faims_cols_all)
    cv_num  <- as.numeric(gsub("[^0-9]", "", cv_part))
    faims_cv_blocks <- lapply(sort(unique(cv_num)), function(n) {
      cols <- faims_cols_all[cv_num == n]
      cols[order(as.integer(sub(".*_rep", "", cols)))]
    })
    names(faims_cv_blocks) <- as.character(sort(unique(cv_num)))
    list(sample = s, di_cols = di_cols, fo_cols = fo_cols,
         faims_cv_blocks = faims_cv_blocks)
  })
  sample_blocks <- sample_blocks[sapply(sample_blocks, function(b)
    length(b$di_cols) > 0 || length(b$fo_cols) > 0 || length(b$faims_cv_blocks) > 0)]
  
  rep_col_labels <- unlist(lapply(sample_blocks, function(b) {
    out <- character(0)
    if (length(b$di_cols) > 0)
      out <- c(out, paste0(b$sample, "_DI_rep", seq_along(b$di_cols)))
    if (length(b$fo_cols) > 0)
      out <- c(out, paste0(b$sample, "_FAIMSoff_rep", seq_along(b$fo_cols)))
    if (length(b$faims_cv_blocks) > 0)
      out <- c(out, paste0(b$sample, "_FAIMS_bestCV_rep",
                           seq_len(length(b$faims_cv_blocks[[1]]))))
    out
  }))
  block_sizes <- unlist(lapply(sample_blocks, function(b) {
    sizes <- c()
    if (length(b$di_cols) > 0)          sizes <- c(sizes, length(b$di_cols))
    if (length(b$fo_cols) > 0)          sizes <- c(sizes, length(b$fo_cols))
    if (length(b$faims_cv_blocks) > 0)  sizes <- c(sizes, length(b$faims_cv_blocks[[1]]))
    sizes
  }))
  
  heat_df <- combined_df %>%
    mutate(
      lipid_label = heat_label_fallback(sum_composition_syn, common_names,
                                        systematic_names, lmsd_ids),
      category    = if_else(is.na(category) | trimws(category) == "",
                            "Uncategorized", category)
    )
  
  all_source_cols <- unlist(lapply(sample_blocks, function(b)
    c(b$di_cols, b$fo_cols, unlist(b$faims_cv_blocks))))
  all_source_cols <- intersect(all_source_cols, colnames(heat_df))
  
  heat_df_avail <- heat_df
  for (b in sample_blocks) {
    s         <- b$sample
    di_cols_s <- intersect(b$di_cols, colnames(heat_df))
    fo_cols_s <- intersect(b$fo_cols, colnames(heat_df))
    faims_cols_s <- intersect(unlist(b$faims_cv_blocks), colnames(heat_df))
    
    heat_df_avail[[paste0(".avail_", s, "_DI")]] <-
      if (length(di_cols_s) > 0) rowSums(!is.na(heat_df[di_cols_s])) > 0 else FALSE
    heat_df_avail[[paste0(".avail_", s, "_FAIMSoff")]] <-
      if (length(fo_cols_s) > 0) rowSums(!is.na(heat_df[fo_cols_s])) > 0 else FALSE
    heat_df_avail[[paste0(".avail_", s, "_FAIMS")]] <-
      if (length(faims_cols_s) > 0) {
        rowSums(sapply(b$faims_cv_blocks, function(cv_cols) {
          cv_cols <- intersect(cv_cols, colnames(heat_df))
          if (length(cv_cols) == 0) return(rep(FALSE, nrow(heat_df)))
          rowMeans(heat_df[cv_cols], na.rm = TRUE) >= abundance_threshold_FAIMS
        })) > 0
      } else FALSE
    
    for (cv_name in names(b$faims_cv_blocks)) {
      cv_cols <- intersect(b$faims_cv_blocks[[cv_name]], colnames(heat_df))
      heat_df_avail[[paste0(".avail_", s, "_FAIMS_", cv_name)]] <-
        if (length(cv_cols) > 0)
          rowMeans(heat_df[cv_cols], na.rm = TRUE) >= abundance_threshold_FAIMS
      else FALSE
    }
  }
  avail_cols <- grep("^\\.avail_", colnames(heat_df_avail), value = TRUE)
  
  heat_collapsed <- heat_df_avail %>%
    mutate(across(all_of(all_source_cols), ~ ifelse(is.na(.x), 0, .x))) %>%
    group_by(lipid_label) %>%
    summarise(
      across(all_of(all_source_cols), sum),
      across(all_of(avail_cols), any),
      category = sort(unique(category))[1],
      .groups = "drop"
    )
  
  label_category <- heat_collapsed %>% select(lipid_label, category)
  
  if (nrow(heat_collapsed) == 0) {
    cat("  WARNING: no rows available for heatmap/table — skipped.\n")
  } else {
    
    n_lip <- nrow(heat_collapsed)
    mat_h <- matrix(NA_real_, nrow = n_lip, ncol = length(rep_col_labels),
                    dimnames = list(heat_collapsed$lipid_label, rep_col_labels))
    avail_h <- matrix(TRUE, nrow = n_lip, ncol = length(rep_col_labels),
                      dimnames = list(heat_collapsed$lipid_label, rep_col_labels))
    best_cv_per_lipid <- setNames(vector("list", length(sample_blocks)),
                                  sapply(sample_blocks, `[[`, "sample"))
    
    for (b in sample_blocks) {
      s <- b$sample
      out_cols <- rep_col_labels[startsWith(rep_col_labels, paste0(s, "_"))]
      
      di_out <- out_cols[grepl("_DI_rep", out_cols)]
      if (length(b$di_cols) > 0 && length(di_out) > 0) {
        mat_h[, di_out] <- as.matrix(heat_collapsed[, b$di_cols])
        di_avail <- heat_collapsed[[paste0(".avail_", s, "_DI")]]
        avail_h[, di_out] <- matrix(rep(di_avail, length(di_out)), ncol = length(di_out))
      }
      
      fo_out <- out_cols[grepl("_FAIMSoff_rep", out_cols)]
      if (length(b$fo_cols) > 0 && length(fo_out) > 0) {
        mat_h[, fo_out] <- as.matrix(heat_collapsed[, b$fo_cols])
        fo_avail <- heat_collapsed[[paste0(".avail_", s, "_FAIMSoff")]]
        avail_h[, fo_out] <- matrix(rep(fo_avail, length(fo_out)), ncol = length(fo_out))
      }
      
      bestcv_out <- out_cols[grepl("_FAIMS_bestCV_rep", out_cols)]
      if (length(b$faims_cv_blocks) > 0 && length(bestcv_out) > 0) {
        cv_names <- names(b$faims_cv_blocks)
        cv_means <- sapply(cv_names, function(cvn) {
          cols <- b$faims_cv_blocks[[cvn]]
          rowMeans(as.matrix(heat_collapsed[, cols]), na.rm = TRUE)
        })
        if (is.null(dim(cv_means))) cv_means <- matrix(cv_means, nrow = n_lip)
        best_idx <- apply(cv_means, 1, function(x) {
          if (all(is.na(x))) return(NA_integer_); which.max(x)
        })
        best_cv_per_lipid[[s]] <- ifelse(is.na(best_idx), NA_character_, cv_names[best_idx])
        for (i in seq_len(n_lip)) {
          if (is.na(best_idx[i])) next
          cols <- b$faims_cv_blocks[[best_idx[i]]]
          mat_h[i, bestcv_out] <- as.numeric(as.matrix(heat_collapsed[i, cols]))
        }
        faims_avail <- heat_collapsed[[paste0(".avail_", s, "_FAIMS")]]
        avail_h[, bestcv_out] <- matrix(rep(faims_avail, length(bestcv_out)),
                                        ncol = length(bestcv_out))
      }
    }
    
    mat_h_full   <- mat_h
    avail_h_full <- avail_h
    best_cv_full <- best_cv_per_lipid
    
    # =========================================================================
    # 14. BEST-CV HEATMAP (endogenous)
    # =========================================================================
    
    if (generate_heatmap) {
      cat("\n========================================\n")
      cat("Category-grouped heatmap (best CV per lipid)\n")
      cat("========================================\n\n")
      
      mat_hm   <- mat_h
      avail_hm <- avail_h
      
      if (!is.null(heatmap_categories) && !identical(heatmap_categories, "all")) {
        keep_labels <- label_category$lipid_label[label_category$category %in% heatmap_categories]
        keep_idx    <- rownames(mat_hm) %in% keep_labels
        mat_hm      <- mat_hm[keep_idx, , drop = FALSE]
        avail_hm    <- avail_hm[keep_idx, , drop = FALSE]
      }
      
      if (nrow(mat_hm) == 0) {
        cat("  WARNING: heatmap_categories filter removed all lipids — best-CV heatmap skipped.\n")
      } else {
        mat_hm[is.na(mat_hm)] <- 0
        log2_hm <- log2(mat_hm + 1); log2_hm[!is.finite(log2_hm)] <- 0
        scaled_hm <- pareto_scale(log2_hm)
        
        row_meta <- data.frame(lipid_label = rownames(mat_hm), stringsAsFactors = FALSE) %>%
          left_join(label_category, by = "lipid_label") %>%
          mutate(category = if_else(is.na(category), "Uncategorized", category))
        
        if (heatmap_cluster_within_category) {
          cat_groups <- split(row_meta$lipid_label, row_meta$category)
          row_ord <- unlist(lapply(sort(names(cat_groups)), function(cat_name) {
            labels_in_cat <- cat_groups[[cat_name]]
            if (length(labels_in_cat) > 1) {
              sub_mat <- scaled_hm[labels_in_cat, , drop = FALSE]
              labels_in_cat[hclust(dist(sub_mat), method = "complete")$order]
            } else labels_in_cat
          }), use.names = FALSE)
          row_meta <- row_meta[match(row_ord, row_meta$lipid_label), ]
        } else {
          row_meta <- row_meta %>% arrange(category, lipid_label)
          row_ord  <- row_meta$lipid_label
        }
        
        long_hm <- data.frame(
          lipid   = rep(rownames(scaled_hm), times = ncol(scaled_hm)),
          x_label = rep(colnames(scaled_hm), each  = nrow(scaled_hm)),
          value   = as.vector(scaled_hm),
          avail   = as.vector(avail_hm)
        ) %>%
          mutate(value   = ifelse(avail, value, NA_real_),
                 lipid   = factor(lipid,   levels = rev(row_ord)),
                 x_label = factor(x_label, levels = rep_col_labels))
        
        x_sep <- cumsum(block_sizes); x_sep <- x_sep[-length(x_sep)] + 0.5
        cat_seq_btt <- rev(row_meta$category)
        cat_counts  <- table(factor(cat_seq_btt, levels = unique(cat_seq_btt)))
        y_sep <- cumsum(as.numeric(cat_counts)); y_sep <- y_sep[-length(y_sep)] + 0.5
        sl <- max(abs(range(long_hm$value, na.rm = TRUE)))
        ph <- max(6, nrow(scaled_hm) * 0.3)
        pw <- length(rep_col_labels) * 0.5 + 4
        
        instr_info <- paste0("DI", if (has_FAIMSoff) " + FAIMSoff" else "",
                             " + FAIMS (best CV per lipid from {",
                             paste(cv_labels, collapse = ", "), "})")
        
        p_heat <- ggplot(long_hm, aes(x = x_label, y = lipid, fill = value)) +
          geom_tile(colour = "white", linewidth = 0.25) +
          { lapply(x_sep, function(xs)
            geom_vline(xintercept = xs, colour = "grey30", linewidth = 0.8)) } +
          { lapply(y_sep, function(ys)
            geom_hline(yintercept = ys, colour = "grey30", linewidth = 0.8)) } +
          scale_fill_gradientn(colours = heatmap_colours, limits = c(-sl, sl),
                               na.value = "grey85", name = "Pareto-scaled\nlog2") +
          scale_x_discrete(position = "top") +
          scale_y_discrete(expand = c(0, 0)) +
          labs(
            title    = sprintf("Lipidome — sum-composition species by category × replicates (%s mode)",
                               toupper(mode)),
            subtitle = paste0("Signal: ", paste(signal_samples, collapse = ", "),
                              " | ", instr_info, "\n",
                              "log2(abundance) | Pareto scaled | rows grouped by LipidMaps Category (A-Z)",
                              " | LMSD matched (\u00b1", ppm_threshold, " ppm)\n",
                              "grey = not detected in that instrument"),
            x = "Sample / condition replicate", y = "Sum-composition lipid") +
          theme_minimal(base_size = 10) +
          theme(axis.text.x       = element_text(angle = 45, hjust = 0, vjust = 0, size = 7),
                axis.text.y       = element_text(size = 7),
                legend.key.height = unit(1.5, "cm"),
                panel.grid        = element_blank(),
                plot.title        = element_text(face = "bold"))
        
        ggsave(sub("\\.xlsx$", "_category_heatmap.pdf", file_output), p_heat,
               width = pw, height = ph, limitsize = FALSE)
        ggsave(sub("\\.xlsx$", "_category_heatmap.png", file_output), p_heat,
               width = pw, height = ph, limitsize = FALSE, dpi = 180)
        cat("Category heatmap (best CV) saved.\n")
        
        ref_table <- row_meta %>% select(category, lipid_label)
        for (s in names(best_cv_per_lipid)) {
          bcv <- best_cv_per_lipid[[s]]
          if (!is.null(bcv)) {
            names(bcv) <- rownames(mat_hm)
            ref_table[[paste0("best_CV_", s)]] <- paste0("CV", bcv[ref_table$lipid_label])
            ref_table[[paste0("best_CV_", s)]][is.na(bcv[ref_table$lipid_label])] <- NA_character_
          }
        }
        write_xlsx_cov(ref_table,
                       sub("\\.xlsx$", "_category_heatmap_categories.xlsx", file_output))
      }
    }
    
    # =========================================================================
    # 15. FAIMS vs DI COMPARISON TABLE (endogenous)
    # =========================================================================
    
    if (generate_faims_di_table) {
      cat("\n========================================\n")
      cat("FAIMS vs DI comparison table\n")
      cat("========================================\n\n")
      
      meta_table <- heat_df %>%
        group_by(lipid_label) %>%
        summarise(
          sum_composition_syn = { v <- sum_composition_syn[!is.na(sum_composition_syn) & sum_composition_syn != ""]; if (length(v) > 0) v[1] else NA_character_ },
          common_name    = paste(unique(common_names[!is.na(common_names) & common_names != ""]), collapse = "; "),
          theoretical_mz = suppressWarnings(min(theoretical_mz, na.rm = TRUE)),
          mz_DI       = { v <- mz_DI[!is.na(mz_DI)];             if (length(v) > 0) v[1] else NA_real_ },
          ppm_DI      = { v <- ppm_DI[!is.na(ppm_DI)];           if (length(v) > 0) v[1] else NA_real_ },
          mz_FAIMSoff = { v <- mz_FAIMSoff[!is.na(mz_FAIMSoff)]; if (length(v) > 0) v[1] else NA_real_ },
          ppm_FAIMSoff= { v <- ppm_FAIMSoff[!is.na(ppm_FAIMSoff)];if(length(v) > 0) v[1] else NA_real_ },
          mz_FAIMS    = { v <- mz_FAIMS[!is.na(mz_FAIMS)];       if (length(v) > 0) v[1] else NA_real_ },
          ppm_FAIMS   = { v <- ppm_FAIMS[!is.na(ppm_FAIMS)];     if (length(v) > 0) v[1] else NA_real_ },
          .groups = "drop"
        ) %>%
        mutate(theoretical_mz = ifelse(is.infinite(theoretical_mz), NA_real_, theoretical_mz))
      
      for (b in sample_blocks) {
        s <- b$sample
        out_cols   <- rep_col_labels[startsWith(rep_col_labels, paste0(s, "_"))]
        di_out     <- out_cols[grepl("_DI_rep",           out_cols)]
        fo_out     <- out_cols[grepl("_FAIMSoff_rep",     out_cols)]
        bestcv_out <- out_cols[grepl("_FAIMS_bestCV_rep", out_cols)]
        
        if (length(di_out) == 0 && length(bestcv_out) == 0) next
        
        lipid_labels <- rownames(mat_h_full)
        n_lip_full   <- length(lipid_labels)
        
        di_vals  <- if (length(di_out) > 0) {
          v <- mat_h_full[, di_out, drop = FALSE]
          v[!avail_h_full[, di_out[1]], ] <- NA_real_; v
        } else matrix(NA_real_, nrow = n_lip_full, ncol = n_replicates)
        di_mean  <- rowMeans(di_vals, na.rm = TRUE); di_mean[is.nan(di_mean)] <- NA_real_
        di_sd    <- apply(di_vals, 1, sd, na.rm = TRUE)
        di_cov   <- (di_sd / di_mean) * 100; di_cov[is.nan(di_cov)] <- NA_real_
        
        fo_mean <- rep(NA_real_, n_lip_full)
        if (length(fo_out) > 0) {
          fo_vals <- mat_h_full[, fo_out, drop = FALSE]
          fo_vals[!avail_h_full[, fo_out[1]], ] <- NA_real_
          fo_mean_tmp <- rowMeans(fo_vals, na.rm = TRUE)
          fo_mean_tmp[is.nan(fo_mean_tmp)] <- NA_real_
          fo_mean <- fo_mean_tmp
        }
        
        faims_vals <- if (length(bestcv_out) > 0) {
          v <- mat_h_full[, bestcv_out, drop = FALSE]
          v[!avail_h_full[, bestcv_out[1]], ] <- NA_real_; v
        } else matrix(NA_real_, nrow = n_lip_full, ncol = n_replicates)
        faims_mean <- rowMeans(faims_vals, na.rm = TRUE); faims_mean[is.nan(faims_mean)] <- NA_real_
        faims_sd   <- apply(faims_vals, 1, sd, na.rm = TRUE)
        faims_cov  <- (faims_sd / faims_mean) * 100; faims_cov[is.nan(faims_cov)] <- NA_real_
        best_cv    <- best_cv_full[[s]]
        best_cv_label <- if (!is.null(best_cv))
          ifelse(is.na(best_cv), NA_character_, paste0("CV", best_cv))
        else rep(NA_character_, n_lip_full)
        
        log2FC  <- log2((faims_mean + 1) / (di_mean + 1))
        p_value <- vapply(seq_len(n_lip_full), function(i) {
          x <- faims_vals[i, ][!is.na(faims_vals[i, ])]
          y <- di_vals[i, ][!is.na(di_vals[i, ])]
          if (length(x) < 2 || length(y) < 2) return(NA_real_)
          alt <- if (mean(x) > mean(y)) "greater" else "less"
          tryCatch(t.test(x, y, alternative = alt, var.equal = FALSE)$p.value,
                   error = function(e) NA_real_)
        }, numeric(1))
        
        m_idx <- match(lipid_labels, meta_table$lipid_label)
        out_df <- data.frame(
          theoretical_mz      = meta_table$theoretical_mz[m_idx],
          sum_composition_syn = meta_table$sum_composition_syn[m_idx],
          common_name         = meta_table$common_name[m_idx],
          mz_DI               = meta_table$mz_DI[m_idx],
          ppm_DI              = meta_table$ppm_DI[m_idx],
          stringsAsFactors    = FALSE
        )
        colnames(di_vals) <- paste0("DI_rep", seq_len(ncol(di_vals)))
        out_df <- cbind(out_df, as.data.frame(di_vals))
        out_df$mean_DI_abundance <- di_mean
        out_df$CoV_pct_DI        <- di_cov
        if (has_FAIMSoff) {
          out_df$mz_FAIMSoff             <- meta_table$mz_FAIMSoff[m_idx]
          out_df$ppm_FAIMSoff            <- meta_table$ppm_FAIMSoff[m_idx]
          out_df$mean_FAIMSoff_abundance <- fo_mean
        }
        out_df$mz_FAIMS  <- meta_table$mz_FAIMS[m_idx]
        out_df$ppm_FAIMS <- meta_table$ppm_FAIMS[m_idx]
        colnames(faims_vals) <- paste0("FAIMS_rep", seq_len(ncol(faims_vals)))
        out_df <- cbind(out_df, as.data.frame(faims_vals))
        out_df$best_CV              <- best_cv_label
        out_df$mean_FAIMS_abundance <- faims_mean
        out_df$CoV_pct_FAIMS        <- faims_cov
        out_df$log2FC_FAIMS_vs_DI   <- round(log2FC, 3)
        out_df$p_value_FAIMS_vs_DI  <- signif(p_value, 4)
        rownames(out_df) <- NULL
        
        out_file <- sub("\\.xlsx$", sprintf("_FAIMS_vs_DI_%s.xlsx", s), file_output)
        write_faims_di_table(out_df, out_file,
                             fc_col       = "log2FC_FAIMS_vs_DI",
                             fc_threshold = faims_di_fc_threshold,
                             p_col        = "p_value_FAIMS_vs_DI")
        cat(sprintf("  %s: %d rows written to %s\n", s, nrow(out_df), out_file))
      }
    }
    
    # =========================================================================
    # 16. ALL-CVs HEATMAP (endogenous)
    # =========================================================================
    
    if (generate_heatmap_all_cv) {
      cat("\n========================================\n")
      cat("All-CVs heatmap\n")
      cat("========================================\n\n")
      
      rep_col_labels2 <- unlist(lapply(sample_blocks, function(b) {
        out <- character(0)
        if (length(b$di_cols) > 0)
          out <- c(out, paste0(b$sample, "_DI_rep", seq_along(b$di_cols)))
        if (length(b$fo_cols) > 0)
          out <- c(out, paste0(b$sample, "_FAIMSoff_rep", seq_along(b$fo_cols)))
        for (cv_name in names(b$faims_cv_blocks))
          out <- c(out, paste0(b$sample, "_FAIMS_CV", cv_name, "_rep",
                               seq_along(b$faims_cv_blocks[[cv_name]])))
        out
      }))
      block_sizes2 <- unlist(lapply(sample_blocks, function(b) {
        sizes <- c()
        if (length(b$di_cols) > 0) sizes <- c(sizes, length(b$di_cols))
        if (length(b$fo_cols) > 0) sizes <- c(sizes, length(b$fo_cols))
        for (cv_name in names(b$faims_cv_blocks))
          sizes <- c(sizes, length(b$faims_cv_blocks[[cv_name]]))
        sizes
      }))
      
      n_lip2   <- nrow(heat_collapsed)
      mat_h2   <- matrix(NA_real_, nrow = n_lip2, ncol = length(rep_col_labels2),
                         dimnames = list(heat_collapsed$lipid_label, rep_col_labels2))
      avail_h2 <- matrix(TRUE, nrow = n_lip2, ncol = length(rep_col_labels2),
                         dimnames = list(heat_collapsed$lipid_label, rep_col_labels2))
      
      for (b in sample_blocks) {
        s        <- b$sample
        out_cols <- rep_col_labels2[startsWith(rep_col_labels2, paste0(s, "_"))]
        di_out   <- out_cols[grepl("_DI_rep", out_cols)]
        if (length(b$di_cols) > 0 && length(di_out) > 0) {
          mat_h2[, di_out]   <- as.matrix(heat_collapsed[, b$di_cols])
          di_avail <- heat_collapsed[[paste0(".avail_", s, "_DI")]]
          avail_h2[, di_out] <- matrix(rep(di_avail, length(di_out)), ncol = length(di_out))
        }
        fo_out <- out_cols[grepl("_FAIMSoff_rep", out_cols)]
        if (length(b$fo_cols) > 0 && length(fo_out) > 0) {
          mat_h2[, fo_out]   <- as.matrix(heat_collapsed[, b$fo_cols])
          fo_avail <- heat_collapsed[[paste0(".avail_", s, "_FAIMSoff")]]
          avail_h2[, fo_out] <- matrix(rep(fo_avail, length(fo_out)), ncol = length(fo_out))
        }
        for (cv_name in names(b$faims_cv_blocks)) {
          cv_out  <- out_cols[grepl(paste0("_FAIMS_CV", cv_name, "_rep"), out_cols)]
          cv_cols <- b$faims_cv_blocks[[cv_name]]
          if (length(cv_out) > 0) {
            mat_h2[, cv_out]   <- as.matrix(heat_collapsed[, cv_cols])
            cv_avail <- heat_collapsed[[paste0(".avail_", s, "_FAIMS_", cv_name)]]
            avail_h2[, cv_out] <- matrix(rep(cv_avail, length(cv_out)), ncol = length(cv_out))
          }
        }
      }
      
      if (!is.null(heatmap_categories) && !identical(heatmap_categories, "all")) {
        keep_labels2 <- label_category$lipid_label[label_category$category %in% heatmap_categories]
        keep_idx2    <- rownames(mat_h2) %in% keep_labels2
        mat_h2   <- mat_h2[keep_idx2, , drop = FALSE]
        avail_h2 <- avail_h2[keep_idx2, , drop = FALSE]
      }
      
      if (nrow(mat_h2) == 0) {
        cat("  WARNING: heatmap_categories filter removed all lipids — all-CVs heatmap skipped.\n")
      } else {
        mat_h2[is.na(mat_h2)] <- 0
        log2_h2 <- log2(mat_h2 + 1); log2_h2[!is.finite(log2_h2)] <- 0
        scaled_h2 <- pareto_scale(log2_h2)
        
        row_meta2 <- data.frame(lipid_label = rownames(mat_h2), stringsAsFactors = FALSE) %>%
          left_join(label_category, by = "lipid_label") %>%
          mutate(category = if_else(is.na(category), "Uncategorized", category))
        
        if (heatmap_cluster_within_category) {
          cat_groups2 <- split(row_meta2$lipid_label, row_meta2$category)
          row_ord2 <- unlist(lapply(sort(names(cat_groups2)), function(cat_name) {
            labels_in_cat <- cat_groups2[[cat_name]]
            if (length(labels_in_cat) > 1) {
              sub_mat <- scaled_h2[labels_in_cat, , drop = FALSE]
              labels_in_cat[hclust(dist(sub_mat), method = "complete")$order]
            } else labels_in_cat
          }), use.names = FALSE)
          row_meta2 <- row_meta2[match(row_ord2, row_meta2$lipid_label), ]
        } else {
          row_meta2 <- row_meta2 %>% arrange(category, lipid_label)
