  draw_IS_boxplot <- function(long_df, title_str, subtitle_str, file_base,
                              add_sig, show_log2FC = FALSE, per_lipid_png = FALSE,
                              n_cols_facet = 4, cond_colours = NULL) {
    if (nrow(long_df) == 0) { cat("  No data - boxplot skipped.\n"); return() }
    if (is.null(cond_colours))
      cond_colours <- c("DI" = "#4472C4", "FAIMSoff" = "#70AD47", "FAIMS" = "#ED7D31")
    
    make_sig_df <- function(df) {
      pairs <- combn(levels(droplevels(df$condition)), 2, simplify = FALSE)
      pairs <- Filter(function(pr) all(pr %in% unique(df$condition)), pairs)
      if (length(pairs) == 0) return(NULL)
      tryCatch({
        tests <- df %>% group_by(IS_lipid) %>%
          filter({ obs <- table(condition); all(obs[names(obs) %in% unlist(pairs)] >= 2) }) %>%
          rstatix::t_test(log2_abun ~ condition, comparisons = pairs, p.adjust.method = "BH")
        rng <- df %>% group_by(IS_lipid) %>%
          summarise(ymax = max(log2_abun, na.rm = TRUE),
                    yspan = diff(range(log2_abun, na.rm = TRUE)), .groups = "drop")
        tests %>% left_join(rng, by = "IS_lipid") %>% group_by(IS_lipid) %>%
          mutate(y.position = ymax + yspan * 0.08 * seq_len(n()),
                 xmin = match(group1, levels(df$condition)),
                 xmax = match(group2, levels(df$condition))) %>% ungroup()
      }, error = function(e) { message("Significance brackets skipped: ", conditionMessage(e)); NULL })
    }
    
    make_fc_df <- function(df, ref = "DI") {
      lv <- levels(droplevels(df$condition)); if (!ref %in% lv) ref <- lv[1]
      means <- df %>% group_by(IS_lipid, condition) %>%
        summarise(mean_abun = mean(2^log2_abun - 1, na.rm = TRUE),
                  ytop = max(log2_abun, na.rm = TRUE), .groups = "drop")
      spans <- df %>% group_by(IS_lipid) %>%
        summarise(pspan = diff(range(log2_abun, na.rm = TRUE)), .groups = "drop")
      ref_m <- means %>% filter(condition == ref) %>% select(IS_lipid, ref_abun = mean_abun)
      means %>% left_join(ref_m, by = "IS_lipid") %>% left_join(spans, by = "IS_lipid") %>%
        filter(condition != ref) %>%
        mutate(log2FC = log2((mean_abun + 1) / (ref_abun + 1)),
               label  = sprintf("%+.2f", log2FC),
               ypos   = ytop + ifelse(is.finite(pspan) & pspan > 0, pspan * 0.05, 0.3)) %>%
        filter(is.finite(log2FC))
    }
    
    sig_df <- if (add_sig)     make_sig_df(long_df) else NULL
    fc_df  <- if (show_log2FC) make_fc_df(long_df)  else NULL
    
    base_plot <- function(df, facet, sig_sub, fc_sub) {
      p <- ggplot(df, aes(x = condition, y = log2_abun, fill = condition)) +
        geom_boxplot(outlier.size = 1.2, alpha = 0.8, width = 0.6) +
        geom_jitter(width = 0.15, size = 0.9, alpha = 0.5) +
        scale_fill_manual(values = cond_colours, guide = "none") +
        labs(x = "Condition / CV", y = "log2(abundance + 1)") +
        theme_minimal(base_size = 10) +
        theme(strip.text  = element_text(size = 7, face = "bold"),
              axis.text.x = element_text(angle = 35, hjust = 1, size = 7),
              plot.title  = element_text(face = "bold"))
      if (facet) p <- p + facet_wrap(~ IS_lipid, scales = "free_y", ncol = n_cols_facet)
      if (!is.null(sig_sub) && nrow(sig_sub) > 0)
        p <- p + ggpubr::stat_pvalue_manual(sig_sub, label = "p.adj.signif",
                                            tip.length = 0.01, size = 3, inherit.aes = FALSE)
      if (!is.null(fc_sub) && nrow(fc_sub) > 0)
        p <- p + geom_text(data = fc_sub, aes(x = condition, y = ypos, label = label),
                           inherit.aes = FALSE, size = 2.8, fontface = "bold", colour = "grey15")
      p
    }
    
    # Faceted overview (unchanged output path)
    p <- base_plot(long_df, TRUE, sig_df, fc_df) +
      labs(title = title_str,
           subtitle = paste0(subtitle_str, if (show_log2FC) "\nnumbers above boxes = log2FC vs DI" else ""))
    n_lip <- length(unique(long_df$IS_lipid))
    n_col <- min(n_cols_facet, n_lip); n_row <- ceiling(n_lip / n_col)
    n_cond <- nlevels(droplevels(long_df$condition))
    ph <- max(5, n_row * 3.5); pw <- n_col * max(2.8, n_cond * 0.45) + 1.5
    ggsave(paste0(file_base, ".pdf"), p, width = pw, height = ph, limitsize = FALSE)
    ggsave(paste0(file_base, ".png"), p, width = pw, height = ph, limitsize = FALSE, dpi = 180)
    cat(sprintf("  Boxplot saved: %s\n", file_base))
    
    # One PNG per IS lipid
    if (per_lipid_png) {
      lip_dir <- paste0(file_base, "_per_lipid")
      dir.create(lip_dir, showWarnings = FALSE, recursive = TRUE)
      for (lip in unique(long_df$IS_lipid)) {
        sub_df <- long_df[long_df$IS_lipid == lip, , drop = FALSE]
        if (nrow(sub_df) == 0) next
        sig_sub <- if (!is.null(sig_df)) sig_df[sig_df$IS_lipid == lip, , drop = FALSE] else NULL
        fc_sub  <- if (!is.null(fc_df))  fc_df[fc_df$IS_lipid == lip, , drop = FALSE]   else NULL
        p_l <- base_plot(sub_df, FALSE, sig_sub, fc_sub) +
          labs(title = lip,
               subtitle = paste0(subtitle_str, if (show_log2FC) " | numbers = log2FC vs DI" else ""))
        ggsave(file.path(lip_dir, paste0(safe_name(lip), ".png")),
               p_l, width = max(3.5, n_cond * 0.7 + 1.5), height = 4.2,
               limitsize = FALSE, dpi = 200)
      }
      cat(sprintf("  Per-lipid PNGs saved in: %s/\n", lip_dir))
    }
  }
  
  # ---------------------------------------------------------------------------
  # 17i. Build long-format boxplot data
  # ---------------------------------------------------------------------------
  
  build_box_long <- function(sample_subset, faims_mode) {
    rows_list <- list()
    
    for (s in sample_subset) {
      # DI
      di_cols <- grep(paste0("^", s, "_rep"), colnames(DI_IS_mat), value = TRUE)
      if (length(di_cols) > 0) {
        sub_mat <- DI_IS_mat[, di_cols, drop = FALSE]
        for (lip in all_is_labels) {
          v <- as.numeric(sub_mat[lip, ]); v <- v[!is.na(v)]
          if (length(v) > 0)
            rows_list <- c(rows_list, lapply(v, function(x)
              data.frame(IS_lipid = lip, sample = s, condition = "DI",
                         log2_abun = log2(x + 1), stringsAsFactors = FALSE)))
        }
      }
      # FAIMSoff
      if (has_FAIMSoff) {
        fo_cols <- grep(paste0("^", s, "_rep"), colnames(FO_IS_mat), value = TRUE)
        if (length(fo_cols) > 0) {
          sub_mat <- FO_IS_mat[, fo_cols, drop = FALSE]
          for (lip in all_is_labels) {
            v <- as.numeric(sub_mat[lip, ]); v <- v[!is.na(v)]
            if (length(v) > 0)
              rows_list <- c(rows_list, lapply(v, function(x)
                data.frame(IS_lipid = lip, sample = s, condition = "FAIMSoff",
                           log2_abun = log2(x + 1), stringsAsFactors = FALSE)))
          }
        }
      }
      # FAIMS
      if (faims_mode == "bestCV") {
        bc_cols <- grep(paste0("^", s, "_FAIMS_bestCV_rep"),
                        colnames(FAIMS_IS_bestcv_mat), value = TRUE)
        if (length(bc_cols) > 0) {
          sub_mat <- FAIMS_IS_bestcv_mat[, bc_cols, drop = FALSE]
          for (lip in all_is_labels) {
            v <- as.numeric(sub_mat[lip, ]); v <- v[!is.na(v)]
            if (length(v) > 0)
              rows_list <- c(rows_list, lapply(v, function(x)
                data.frame(IS_lipid = lip, sample = s, condition = "FAIMS",
                           log2_abun = log2(x + 1), stringsAsFactors = FALSE)))
          }
        }
      } else {
        for (cv in cv_labels) {
          cv_cols <- grep(paste0("^", s, "_FAIMS_", cv, "_rep"),
                          colnames(FAIMS_IS_allcv_mat), value = TRUE)
          if (length(cv_cols) == 0) next
          sub_mat <- FAIMS_IS_allcv_mat[, cv_cols, drop = FALSE]
          for (lip in all_is_labels) {
            v <- as.numeric(sub_mat[lip, ]); v <- v[!is.na(v)]
            if (length(v) > 0)
              rows_list <- c(rows_list, lapply(v, function(x)
                data.frame(IS_lipid = lip, sample = s, condition = cv,
                           log2_abun = log2(x + 1), stringsAsFactors = FALSE)))
          }
        }
      }
    }
    
    if (length(rows_list) == 0) return(data.frame())
    df <- bind_rows(rows_list)
    lvls <- if (faims_mode == "bestCV")
      c("DI", if (has_FAIMSoff) "FAIMSoff", "FAIMS")
    else
      c("DI", if (has_FAIMSoff) "FAIMSoff", cv_labels)
    df$condition <- factor(df$condition, levels = intersect(lvls, unique(df$condition)))
    df
  }
  
