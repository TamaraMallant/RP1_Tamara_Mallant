  # 17k. Boxplots — all CVs
  # ---------------------------------------------------------------------------
  
  cat("\n--- IS boxplots (all CVs) ---\n")
  
  for (s in is_signal_samples) {
    long_s_acv <- build_box_long(s, "allCV")
