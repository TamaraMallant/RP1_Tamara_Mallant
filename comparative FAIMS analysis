  rep_vals_is <- function(mat, pattern) {
    cols <- grep(pattern, colnames(mat), value = TRUE)
    if (length(cols) == 0)
      return(matrix(NA_real_, nrow = nrow(mat), ncol = n_replicates))
    as.matrix(mat[, cols, drop = FALSE])
  }
  
  rep_mean_is <- function(mat, pattern) {
    v <- rowMeans(rep_vals_is(mat, pattern), na.rm = TRUE)
    v[is.nan(v)] <- NA_real_; v
  }
  
  rep_cov_is <- function(mat, pattern) {
    m  <- rep_vals_is(mat, pattern)
    mu <- rowMeans(m, na.rm = TRUE)
    sg <- apply(m, 1, sd, na.rm = TRUE)
    v  <- (sg / mu) * 100; v[is.nan(v)] <- NA_real_; v
  }
  
  pairwise_stats_is <- function(vals_a, vals_b) {
    log2fc <- log2((rowMeans(vals_b, na.rm = TRUE) + 1) /
                     (rowMeans(vals_a, na.rm = TRUE) + 1))
    pval <- vapply(seq_len(nrow(vals_a)), function(i) {
      x <- vals_b[i, ][!is.na(vals_b[i, ])]
      y <- vals_a[i, ][!is.na(vals_a[i, ])]
      if (length(x) < 2 || length(y) < 2) return(NA_real_)
      tryCatch(t.test(x, y, var.equal = FALSE)$p.value,
               error = function(e) NA_real_)
    }, numeric(1))
    list(log2fc = round(log2fc, 3), pval = signif(pval, 4))
  }
  
