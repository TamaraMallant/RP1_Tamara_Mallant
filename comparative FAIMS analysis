      scale_x_discrete(position = "top") +
      scale_y_discrete(expand = c(0, 0)) +
      labs(title = title_str, subtitle = subtitle_str, x = NULL, y = "IS lipid") +
      theme_minimal(base_size = 10) +
      theme(axis.text.x       = element_text(angle = 45, hjust = 0, vjust = 0, size = 7),
            axis.text.y       = element_text(size = 8),
            legend.key.height = unit(1.5, "cm"),
            panel.grid        = element_blank(),
            plot.title        = element_text(face = "bold"))
    
    ggsave(paste0(file_base, ".pdf"), p, width = pw, height = ph, limitsize = FALSE)
    ggsave(paste0(file_base, ".png"), p, width = pw, height = ph,
