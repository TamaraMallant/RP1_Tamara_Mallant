      cond_colours = pal_s)
  }
  
  long_all_acv <- build_box_long(is_signal_samples, "allCV")
  if (nrow(long_all_acv) > 0) {
    pal_all <- make_allcv_colours(long_all_acv)
    p_all_acv <- ggplot(long_all_acv,
                        aes(x = condition, y = log2_abun, fill = condition)) +
      geom_boxplot(outlier.size = 1, alpha = 0.8, width = 0.6) +
      geom_jitter(width = 0.12, size = 0.7, alpha = 0.4) +
      scale_fill_manual(values = pal_all, guide = "none") +
      facet_grid(IS_lipid ~ sample, scales = "free_y") +
      labs(title    = sprintf("IS lipid abundance — all samples, all CVs (%s mode)", toupper(mode)),
           subtitle = sprintf("rows = IS lipid | cols = sample | DI%s + FAIMS CVs {%s} | \u00b1%g ppm",
                              if (has_FAIMSoff) " + FAIMSoff" else "",
                              paste(cv_labels, collapse = ", "), ppm_threshold),
           x = "Condition / CV", y = "log2(abundance + 1)") +
      theme_minimal(base_size = 9) +
      theme(strip.text.y = element_text(size = 7, angle = 0, face = "bold"),
            strip.text.x = element_text(size = 8, face = "bold"),
            axis.text.x  = element_text(angle = 45, hjust = 1, size = 6),
            plot.title   = element_text(face = "bold"))
    
    ph_acv <- max(5, n_is * 3.2)
    pw_acv <- length(is_signal_samples) * max(4, length(cv_labels) * 0.55) + 2
    ggsave(sub("\\.xlsx$", "_IS_boxplot_all_samples_allCV.pdf", file_output),
           p_all_acv, width = pw_acv, height = ph_acv, limitsize = FALSE)
    ggsave(sub("\\.xlsx$", "_IS_boxplot_all_samples_allCV.png", file_output),
           p_all_acv, width = pw_acv, height = ph_acv, limitsize = FALSE, dpi = 180)
    cat("  Boxplot saved: IS_boxplot_all_samples_allCV\n")
  }
  
  # ---------------------------------------------------------------------------
  # 17l-extra. Log10 abundance spread boxplot — one box per condition,
  #            all IS lipids x all samples pooled as observations.
  #            Shows overall signal level and spread; each dot = one replicate.
  # ---------------------------------------------------------------------------
  
  cat("\n--- IS log10 abundance spread boxplot ---\n")
  
  if (exists("long_all_bcv") && nrow(long_all_bcv) > 0) {
    
    spread_df <- long_all_bcv %>%
      mutate(
        abundance  = 2^log2_abun - 1,
        log10_abun = log10(abundance + 1),
        condition  = factor(condition, levels = levels(long_all_bcv$condition))
      )
    
    cond_colours_spread <- c("DI" = "#4472C4", "FAIMSoff" = "#70AD47", "FAIMS" = "#ED7D31")
    
    p_spread <- ggplot(spread_df,
                       aes(x = condition, y = log10_abun, fill = condition)) +
      geom_boxplot(outlier.shape = NA, alpha = 0.8, width = 0.55) +
      geom_jitter(aes(colour = IS_lipid), width = 0.18, size = 1.8,
                  alpha = 0.7, show.legend = TRUE) +
      scale_fill_manual(values = cond_colours_spread, guide = "none") +
      scale_colour_discrete(name = "IS lipid") +
      facet_wrap(~ sample, nrow = 1) +
      labs(
        title    = sprintf("IS lipid abundance spread per condition (%s mode)", toupper(mode)),
        subtitle = sprintf(
          "All IS lipids pooled | DI%s + FAIMS best CV | \u00b1%g ppm | each point = 1 replicate, coloured by IS lipid",
          if (has_FAIMSoff) " + FAIMSoff" else "", ppm_threshold),
        x = "Condition", y = "log10(abundance + 1)"
      ) +
      theme_minimal(base_size = 11) +
      theme(strip.text      = element_text(size = 10, face = "bold"),
            axis.text.x     = element_text(angle = 30, hjust = 1, size = 9),
            plot.title      = element_text(face = "bold"),
            legend.position = "right",
            legend.text     = element_text(size = 8))
    
    pw_sp <- length(is_signal_samples) * 3.5 + 3
    ph_sp <- 5
    
    ggsave(sub("\\.xlsx$", "_IS_boxplot_spread_bestCV.pdf", file_output),
           p_spread, width = pw_sp, height = ph_sp, limitsize = FALSE)
    ggsave(sub("\\.xlsx$", "_IS_boxplot_spread_bestCV.png", file_output),
           p_spread, width = pw_sp, height = ph_sp, limitsize = FALSE, dpi = 300)
    cat("  Boxplot saved: IS_boxplot_spread_bestCV\n")
  }
  
  # ---------------------------------------------------------------------------
  # 17l. Per-sample Excel output
  # ---------------------------------------------------------------------------
  
  cat("\n--- IS Excel output (per sample) ---\n")
  
  conditions_excel <- c("DI", if (has_FAIMSoff) "FAIMSoff", "FAIMS")
  
  for (s in is_signal_samples) {
    
    di_rep_cols    <- rep_vals_is(DI_IS_mat,          paste0("^", s, "_rep"))
    fo_rep_cols    <- rep_vals_is(FO_IS_mat,           paste0("^", s, "_rep"))
    faims_rep_cols <- rep_vals_is(FAIMS_IS_bestcv_mat, paste0("^", s, "_FAIMS_bestCV_rep"))
    
    di_mean    <- rowMeans(di_rep_cols,    na.rm = TRUE); di_mean[is.nan(di_mean)]       <- NA_real_
    fo_mean    <- rowMeans(fo_rep_cols,    na.rm = TRUE); fo_mean[is.nan(fo_mean)]       <- NA_real_
    faims_mean <- rowMeans(faims_rep_cols, na.rm = TRUE); faims_mean[is.nan(faims_mean)] <- NA_real_
    
    di_cov    <- rep_cov_is(DI_IS_mat,          paste0("^", s, "_rep"))
    fo_cov    <- rep_cov_is(FO_IS_mat,           paste0("^", s, "_rep"))
    faims_cov <- rep_cov_is(FAIMS_IS_bestcv_mat, paste0("^", s, "_FAIMS_bestCV_rep"))
    
    cond_means <- cbind(DI       = di_mean,
                        FAIMSoff = if (has_FAIMSoff) fo_mean else NA_real_,
                        FAIMS    = faims_mean)
    best_cond <- apply(cond_means, 1, function(x) {
      x[is.nan(x)] <- NA
      if (all(is.na(x))) return(NA_character_)
      conditions_excel[which.max(x)]
    })
    
    di_vs_fo    <- if (has_FAIMSoff) pairwise_stats_is(di_rep_cols, fo_rep_cols)
    else list(log2fc = rep(NA_real_, n_is), pval = rep(NA_real_, n_is))
    di_vs_faims <- pairwise_stats_is(di_rep_cols, faims_rep_cols)
    faims_vs_fo <- if (has_FAIMSoff) pairwise_stats_is(faims_rep_cols, fo_rep_cols)
    else list(log2fc = rep(NA_real_, n_is), pval = rep(NA_real_, n_is))
    
    out <- data.frame(IS_lipid_name = all_is_labels,
                      IS_lipid_mz   = round(theo_mz_vec, 5),
                      stringsAsFactors = FALSE)
    
    di_rep_df <- as.data.frame(di_rep_cols)
    colnames(di_rep_df) <- paste0("DI_rep", seq_len(n_replicates))
    out <- cbind(out, di_rep_df)
    
    if (has_FAIMSoff) {
      fo_rep_df <- as.data.frame(fo_rep_cols)
      colnames(fo_rep_df) <- paste0("FAIMSoff_rep", seq_len(n_replicates))
      out <- cbind(out, fo_rep_df)
    }
    
    faims_rep_df <- as.data.frame(faims_rep_cols)
    colnames(faims_rep_df) <- paste0("FAIMS_bestCV_rep", seq_len(n_replicates))
    out <- cbind(out, faims_rep_df)
    out$FAIMS_best_CV <- best_cv_is[all_is_labels, s]
    
    out$mean_DI    <- round(di_mean, 1)
    if (has_FAIMSoff) out$mean_FAIMSoff <- round(fo_mean, 1)
    out$mean_FAIMS <- round(faims_mean, 1)
    
    out$CoV_pct_DI    <- round(di_cov,    2)
    if (has_FAIMSoff) out$CoV_pct_FAIMSoff <- round(fo_cov, 2)
    out$CoV_pct_FAIMS <- round(faims_cov, 2)
    
    out$mz_DI   <- round(mz_ppm_DI$mz,   5); out$ppm_DI   <- round(mz_ppm_DI$ppm,   4)
    if (has_FAIMSoff) {
      out$mz_FAIMSoff  <- round(mz_ppm_FO$mz,  5)
      out$ppm_FAIMSoff <- round(mz_ppm_FO$ppm, 4)
    }
    out$mz_FAIMS  <- round(mz_ppm_FAIMS$mz,  5)
    out$ppm_FAIMS <- round(mz_ppm_FAIMS$ppm, 4)
    
    out$best_condition               <- best_cond
    out$log2FC_FAIMSoff_vs_DI        <- di_vs_fo$log2fc
    out$log2FC_FAIMS_vs_DI           <- di_vs_faims$log2fc
    out$log2FC_FAIMSoff_vs_FAIMS     <- faims_vs_fo$log2fc
    out$pval_ttest_FAIMSoff_vs_DI    <- di_vs_fo$pval
    out$pval_ttest_FAIMS_vs_DI       <- di_vs_faims$pval
    out$pval_ttest_FAIMSoff_vs_FAIMS <- faims_vs_fo$pval
    
    wb_s <- createWorkbook()
    addWorksheet(wb_s, "IS_results")
    writeData(wb_s, "IS_results", out)
    addStyle(wb_s, "IS_results",
             createStyle(fontName = "Arial", fontSize = 11, fontColour = "#FFFFFF",
                         fgFill = "#2F5496", halign = "CENTER",
                         textDecoration = "Bold", wrapText = TRUE),
             rows = 1, cols = 1:ncol(out), gridExpand = TRUE)
    
    cov_col_map <- list(
      CoV_pct_DI       = list(green = cov_green_DI,       yellow = cov_yellow_DI),
      CoV_pct_FAIMSoff = list(green = cov_green_FAIMSoff, yellow = cov_yellow_FAIMSoff),
      CoV_pct_FAIMS    = list(green = cov_green_FAIMS,    yellow = cov_yellow_FAIMS))
    for (cn in intersect(names(cov_col_map), colnames(out))) {
      color_cov_column(wb_s, "IS_results", which(colnames(out) == cn), out[[cn]],
                       cov_col_map[[cn]]$green, cov_col_map[[cn]]$yellow)
    }
    for (pc in grep("^pval_", colnames(out), value = TRUE)) {
      idx <- which(colnames(out) == pc)
      sig_rows <- which(!is.na(out[[pc]]) & out[[pc]] < 0.05)
      if (length(sig_rows))
        addStyle(wb_s, "IS_results", createStyle(fgFill = "#C6EFCE"),
                 rows = sig_rows + 1, cols = idx, gridExpand = TRUE, stack = TRUE)
    }
    for (fc in grep("^log2FC_", colnames(out), value = TRUE)) {
      idx <- which(colnames(out) == fc)
      sig_rows <- which(!is.na(out[[fc]]) & abs(out[[fc]]) > 1)
      if (length(sig_rows))
        addStyle(wb_s, "IS_results", createStyle(fgFill = "#FCE4D6"),
                 rows = sig_rows + 1, cols = idx, gridExpand = TRUE, stack = TRUE)
    }
    freezePane(wb_s, "IS_results", firstRow = TRUE)
    setColWidths(wb_s, "IS_results", cols = 1:ncol(out),
                 widths = c(30, 14, rep(12, ncol(out) - 2)))
    
    out_file_s <- sub("\\.xlsx$", sprintf("_IS_output_%s.xlsx", s), file_output)
    saveWorkbook(wb_s, out_file_s, overwrite = TRUE)
    cat(sprintf("  %s: %d IS lipids written to %s\n", s, n_is, out_file_s))
  }
  
