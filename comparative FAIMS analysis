count_zeros <- function(df, cols) {
  rowSums(df[, cols, drop = FALSE] == 0, na.rm = TRUE)
}

max_blank_mean <- function(df, blank_groups) {
  means_mat <- sapply(blank_groups, function(cols) {
    rowMeans(df[, intersect(cols, colnames(df)), drop = FALSE], na.rm = TRUE)
  })
  if (is.null(dim(means_mat))) means_mat <- matrix(means_mat, ncol = length(blank_groups))
  apply(means_mat, 1, max, na.rm = TRUE)
}

color_cov_column <- function(wb, sheet, col_index, cov_values,
                             green_thresh, yellow_thresh, start_row = 2) {
  # Batch by colour: 3 addStyle calls total regardless of row count,
  # instead of one per row (extremely slow on large sheets).
  row_indices <- start_row - 1L + seq_along(cov_values)
  green_rows  <- row_indices[!is.na(cov_values) & cov_values <  green_thresh]
  yellow_rows <- row_indices[!is.na(cov_values) & cov_values >= green_thresh &
                               cov_values <= yellow_thresh]
  red_rows    <- row_indices[is.na(cov_values)  | cov_values >  yellow_thresh]
  if (length(green_rows)  > 0)
    addStyle(wb, sheet, createStyle(fgFill = "#00B050"),
             rows = green_rows,  cols = col_index, gridExpand = FALSE, stack = TRUE)
  if (length(yellow_rows) > 0)
    addStyle(wb, sheet, createStyle(fgFill = "#FFFF00"),
             rows = yellow_rows, cols = col_index, gridExpand = FALSE, stack = TRUE)
  if (length(red_rows)    > 0)
    addStyle(wb, sheet, createStyle(fgFill = "#FF0000"),
             rows = red_rows,    cols = col_index, gridExpand = FALSE, stack = TRUE)
}

write_xlsx_cov <- function(df, file, cov_meta = list()) {
  wb <- createWorkbook()
  addWorksheet(wb, "Results")
  writeData(wb, "Results", df)
  for (cn in names(cov_meta)) {
    idx <- which(colnames(df) == cn)
    if (length(idx))
      color_cov_column(wb, "Results", idx, df[[cn]],
                       green_thresh  = cov_meta[[cn]]$green,
                       yellow_thresh = cov_meta[[cn]]$yellow)
  }
  saveWorkbook(wb, file, overwrite = TRUE)
  cat("Written:", file, "\n")
}

write_faims_di_table <- function(df, file, fc_col, fc_threshold, p_col) {
  wb <- createWorkbook()
  addWorksheet(wb, "Results")
  writeData(wb, "Results", df)
  green <- createStyle(fgFill = "#C6EFCE")
  fc_idx <- which(colnames(df) == fc_col)
  if (length(fc_idx)) {
    sig_rows <- which(!is.na(df[[fc_col]]) & abs(df[[fc_col]]) > fc_threshold)
    if (length(sig_rows))
      addStyle(wb, "Results", green, rows = sig_rows + 1, cols = fc_idx,
               gridExpand = TRUE, stack = TRUE)
  }
  p_idx <- which(colnames(df) == p_col)
  if (length(p_idx)) {
    sig_rows <- which(!is.na(df[[p_col]]) & df[[p_col]] < 0.05)
    if (length(sig_rows))
      addStyle(wb, "Results", green, rows = sig_rows + 1, cols = p_idx,
               gridExpand = TRUE, stack = TRUE)
  }
  saveWorkbook(wb, file, overwrite = TRUE)
  cat("Written:", file, "\n")
}

print_cov_summary <- function(cov_vec, label, green_thresh, yellow_thresh) {
  cat(sprintf("%s CoV summary:\n", label))
  cat(sprintf("  <%.0f%%    : %d\n",  green_thresh,
              sum(cov_vec <  green_thresh, na.rm = TRUE)))
  cat(sprintf("  %.0f-%.0f%%: %d\n",  green_thresh, yellow_thresh,
              sum(cov_vec >= green_thresh & cov_vec <= yellow_thresh, na.rm = TRUE)))
  cat(sprintf("  >%.0f%%    : %d\n",  yellow_thresh,
              sum(cov_vec >  yellow_thresh, na.rm = TRUE)))
}

pareto_scale <- function(mat) {
  scaled <- t(apply(mat, 1, function(x) {
    mu  <- mean(x, na.rm = TRUE)
    sig <- sd(x,   na.rm = TRUE)
    if (is.na(mu) || is.na(sig) || sig == 0) return(x - mu)
    (x - mu) / sqrt(sig)
  }))
  colnames(scaled) <- colnames(mat)
  scaled
}

match_lmsd <- function(df, ref_df, adduct_cols, adduct_labels,
                       ppm_thresh, source_tag) {
  result <- lapply(seq_len(nrow(df)), function(i) {
    measured  <- df$mz[i]
    hits_list <- lapply(seq_along(adduct_cols), function(a) {
      theo       <- ref_df[[adduct_cols[a]]]
      ppm_errors <- ((measured - theo) / theo) * 1e6
      idx        <- which(abs(ppm_errors) <= ppm_thresh & !is.na(ppm_errors))
      if (length(idx) == 0L) return(NULL)
      do.call(rbind, lapply(idx, function(h) {
        cbind(
          data.frame(
            lmsd_id             = ref_df$`LipidMaps ID`[h],
            sum_composition_syn = ref_df$`Sum composition synonym`[h],
            common_name         = ref_df$`Common name`[h],
            systematic_name     = ref_df$`Systematic name`[h],
            category            = ref_df$Category[h],
            main_class          = ref_df$`Main class`[h],
            sub_class           = ref_df$`Sub class`[h],
            kegg_id             = ref_df$`KEGG ID`[h],
            adduct              = adduct_labels[a],
            theoretical_mz      = theo[h],
            ppm_error           = round(ppm_errors[h], 4),
            stringsAsFactors    = FALSE
          ),
          df[i, , drop = FALSE]
        )
      }))
    })
    do.call(rbind, hits_list)
  })
  out <- bind_rows(result)
  if (nrow(out) > 0) out$source <- source_tag
  out
}

collapse_to_sum_composition <- function(matched_df) {
  if (nrow(matched_df) == 0) return(matched_df)
  matched_df$group_key <- ifelse(
    !is.na(matched_df$sum_composition_syn) & matched_df$sum_composition_syn != "",
    paste(matched_df$sum_composition_syn, matched_df$adduct, sep = "|||"),
    paste(matched_df$lmsd_id,             matched_df$adduct, sep = "|||")
  )
  fixed_cols <- c("lmsd_id", "sum_composition_syn", "common_name",
                  "systematic_name", "category", "main_class", "sub_class",
                  "kegg_id", "adduct", "theoretical_mz", "ppm_error",
                  "mz", "source", "passing_CVs", "group_key")
  abun_cols <- setdiff(colnames(matched_df), fixed_cols)
  result <- lapply(unique(matched_df$group_key), function(key) {
    grp    <- matched_df[matched_df$group_key == key, , drop = FALSE]
    best_i <- which.min(abs(grp$ppm_error))
    collapse_unique <- function(x)
      paste(unique(x[!is.na(x) & x != ""]), collapse = "; ")
    out <- grp[best_i, , drop = FALSE]
    out$lmsd_id         <- collapse_unique(grp$lmsd_id)
    out$common_name     <- collapse_unique(grp$common_name)
    out$systematic_name <- collapse_unique(grp$systematic_name)
    out$kegg_id         <- collapse_unique(grp$kegg_id)
    if ("passing_CVs" %in% colnames(grp)) {
      all_cvs <- unique(unlist(strsplit(
        grp$passing_CVs[!is.na(grp$passing_CVs)], ",\\s*")))
      out$passing_CVs <- if (length(all_cvs) > 0)
        paste(sort(all_cvs), collapse = ", ") else NA_character_
    }
    out[, abun_cols] <- grp[best_i, abun_cols, drop = FALSE]
    out
  })
  bind_rows(result)
}

# ---------------------------------------------------------------------------
# Generic DI-style pipeline — parameterised for endogenous and IS runs
# ---------------------------------------------------------------------------
run_di_style_pipeline <- function(raw_df,
                                  sample_cols_list,
                                  signal_samples,
                                  blank_samples,
                                  n_replicates,
                                  abundance_threshold,
                                  fold_change_threshold,
                                  max_zeros_allowed,
                                  cov_green, cov_yellow,
                                  cov_filter_remove,
                                  lmsd, adduct_cols, adduct_labels,
                                  ppm_threshold,
                                  source_tag,
                                  file_filtered, file_matched) {
  
  signal_cols_list <- sample_cols_list[signal_samples]
  blank_groups     <- sample_cols_list[blank_samples]
  n_sig            <- length(signal_samples)
  
  # Filter 1: Missingness
  miss_ok <- sapply(signal_cols_list, function(cols)
    count_zeros(raw_df, cols) < max_zeros_allowed)
  if (is.null(dim(miss_ok))) miss_ok <- matrix(miss_ok, ncol = n_sig)
  filt <- raw_df[rowSums(miss_ok) >= 1, ]
  cat(sprintf("%s — after missingness filter (<%d zeros in >= 1 signal): %d of %d retained\n",
              source_tag, max_zeros_allowed, nrow(filt), nrow(raw_df)))
  
  # Filter 2: Abundance
  abun_ok <- sapply(signal_cols_list, function(cols)
    rowMeans(filt[, cols, drop = FALSE], na.rm = TRUE) >= abundance_threshold)
  if (is.null(dim(abun_ok))) abun_ok <- matrix(abun_ok, ncol = n_sig)
  filt <- filt[rowSums(abun_ok) >= 1, ]
  cat(sprintf("%s — after abundance filter (>= %s in >= 1 signal): %d retained\n",
              source_tag, format(abundance_threshold, big.mark = ","), nrow(filt)))
  
  # Filter 3: Fold change
  fc_ok <- sapply(signal_cols_list, function(sig_cols) {
    mean_sig <- rowMeans(filt[, sig_cols, drop = FALSE], na.rm = TRUE)
    max_bl   <- max_blank_mean(filt, blank_groups)
    ((mean_sig + 1) / (max_bl + 1)) >= fold_change_threshold
  })
  if (is.null(dim(fc_ok))) fc_ok <- matrix(fc_ok, ncol = n_sig)
  filt <- filt[rowSums(fc_ok) >= 1, ]
  cat(sprintf("%s — after fold-change filter (>= %.1f in >= 1 signal): %d retained\n",
              source_tag, fold_change_threshold, nrow(filt)))
  
  # Per-signal CoV
  cov_col_names <- character(n_sig)
  for (s in signal_samples) {
    cols    <- sample_cols_list[[s]]
    mean_s  <- rowMeans(filt[, cols, drop = FALSE], na.rm = TRUE)
    sd_s    <- apply(   filt[, cols, drop = FALSE], 1, sd, na.rm = TRUE)
    cov_col <- paste0("CoV_pct_", s)
    cov_col_names[match(s, signal_samples)] <- cov_col
    filt[[paste0("mean_", s)]] <- mean_s
    filt[[cov_col]]            <- (sd_s / mean_s) * 100
  }
  cat("\n")
  for (s in signal_samples)
    print_cov_summary(filt[[paste0("CoV_pct_", s)]],
                      paste(source_tag, s), cov_green, cov_yellow)
  
  if (cov_filter_remove) {
    n_before <- nrow(filt)
    cov_fail <- rowSums(sapply(cov_col_names, function(cn)
      !is.na(filt[[cn]]) & filt[[cn]] >= cov_green)) == n_sig
    filt <- filt[!cov_fail, ]
    cat(sprintf("%s — after CoV filter (>= 1 signal < %.0f%%): %d of %d retained\n",
                source_tag, cov_green, nrow(filt), n_before))
  }
  cat("\n")
  
  cov_meta <- setNames(
    lapply(cov_col_names, function(cn) list(green = cov_green, yellow = cov_yellow)),
    cov_col_names)
  write_xlsx_cov(filt, file_filtered, cov_meta)
  
  matched_raw <- match_lmsd(filt, lmsd, adduct_cols, adduct_labels, ppm_threshold, source_tag)
  matched     <- collapse_to_sum_composition(matched_raw)
  cat(sprintf("%s — LMSD-matched rows (before collapse): %d\n", source_tag, nrow(matched_raw)))
  cat(sprintf("%s — after sum-composition collapse:      %d\n\n", source_tag, nrow(matched)))
  write_xlsx_cov(matched, file_matched, cov_meta)
  
  list(filt = filt, matched = matched, cov_meta = cov_meta,
       sample_cols = sample_cols_list)
}

# ---------------------------------------------------------------------------
# Generic FAIMS pipeline — shared for endogenous and IS
# ---------------------------------------------------------------------------
run_faims_pipeline <- function(raw_df,
                               signal_by_CV,
                               blank_by_CV,
                               sample_cols,
                               signal_samples,
                               abundance_threshold,
                               fold_change_threshold,
                               max_zeros_allowed,
                               cov_green, cov_yellow,
                               cov_filter_remove,
                               lmsd_ref, adduct_cols, adduct_labels,
                               ppm_threshold,
                               source_tag,
                               file_filtered, file_matched) {
  
  n_sig  <- length(signal_samples)
  n_cond <- length(cv_labels)
  
  # Filter 1: Missingness
  miss_ok <- sapply(signal_by_CV, function(sig_cv_list) {
    cv_pass <- sapply(sig_cv_list, function(cols)
      count_zeros(raw_df, cols) < max_zeros_allowed)
    if (is.null(dim(cv_pass))) cv_pass <- matrix(cv_pass, ncol = n_cond)
    rowSums(cv_pass) >= 1
  })
  if (is.null(dim(miss_ok))) miss_ok <- matrix(miss_ok, ncol = n_sig)
  filt <- raw_df[rowSums(miss_ok) >= 1, ]
  cat(sprintf("%s — after missingness filter: %d of %d retained\n",
              source_tag, nrow(filt), nrow(raw_df)))
  
  # Filter 2: Abundance
  abun_ok <- sapply(signal_by_CV, function(sig_cv_list) {
    cv_pass <- sapply(sig_cv_list, function(cols)
      rowMeans(filt[, cols, drop = FALSE], na.rm = TRUE) >= abundance_threshold)
    if (is.null(dim(cv_pass))) cv_pass <- matrix(cv_pass, ncol = n_cond)
    rowSums(cv_pass) >= 1
  })
  if (is.null(dim(abun_ok))) abun_ok <- matrix(abun_ok, ncol = n_sig)
  filt <- filt[rowSums(abun_ok) >= 1, ]
  cat(sprintf("%s — after abundance filter: %d retained\n", source_tag, nrow(filt)))
  
  # Filter 3: FC (CV-matched signal vs CV-matched blank)
  fc_ok <- sapply(signal_by_CV, function(sig_cv_list) {
    cv_pass <- sapply(seq_along(cv_labels), function(i) {
      mean_sig       <- rowMeans(filt[, sig_cv_list[[i]], drop = FALSE], na.rm = TRUE)
      blank_groups_i <- lapply(blank_by_CV, `[[`, i)
      max_bl         <- max_blank_mean(filt, blank_groups_i)
      ((mean_sig + 1) / (max_bl + 1)) >= fold_change_threshold
    })
    if (is.null(dim(cv_pass))) cv_pass <- matrix(cv_pass, ncol = n_cond)
    rowSums(cv_pass) >= 1
  })
  if (is.null(dim(fc_ok))) fc_ok <- matrix(fc_ok, ncol = n_sig)
  filt <- filt[rowSums(fc_ok) >= 1, ]
  cat(sprintf("%s — after fold-change filter: %d retained\n\n", source_tag, nrow(filt)))
  
  # Per-signal, per-CV CoV
  cov_cols_out  <- setNames(vector("list", n_sig), signal_samples)
  faims_cv_pass <- setNames(vector("list", n_sig), signal_samples)
  
  for (s in signal_samples) {
    sig_cv_list     <- signal_by_CV[[s]]
    cov_col_names_s <- character(n_cond)
    cv_pass_s       <- matrix(FALSE, nrow = nrow(filt), ncol = n_cond)
    for (i in seq_along(cv_labels)) {
      cols     <- sig_cv_list[[i]]
      mean_s   <- rowMeans(filt[, cols, drop = FALSE], na.rm = TRUE)
      sd_s     <- apply(   filt[, cols, drop = FALSE], 1, sd, na.rm = TRUE)
      mean_col <- paste0("mean_", s, "_", cv_labels[i])
      cov_col  <- paste0("CoV_pct_", s, "_", cv_labels[i])
      cov_col_names_s[i] <- cov_col
      filt[[mean_col]] <- mean_s
      filt[[cov_col]]  <- (sd_s / mean_s) * 100
      abun_pass_i    <- mean_s >= abundance_threshold
      blank_groups_i <- lapply(blank_by_CV, `[[`, i)
      max_bl_i       <- max_blank_mean(filt, blank_groups_i)
      fc_pass_i      <- ((mean_s + 1) / (max_bl_i + 1)) >= fold_change_threshold
      cov_pass_i     <- if (cov_filter_remove)
        (filt[[cov_col]] < cov_green) else rep(TRUE, nrow(filt))
      cv_pass_s[, i] <- abun_pass_i & fc_pass_i & cov_pass_i
      v <- filt[[cov_col]]
      cat(sprintf("%s CoV %s %s:  <%.0f%%: %d | %.0f-%.0f%%: %d | >%.0f%%: %d\n",
                  source_tag, s, cv_labels[i],
                  cov_green,  sum(v <  cov_green,  na.rm = TRUE),
                  cov_green,  cov_yellow,
                  sum(v >= cov_green & v <= cov_yellow, na.rm = TRUE),
                  cov_yellow, sum(v >  cov_yellow, na.rm = TRUE)))
    }
    cov_cols_out[[s]]  <- cov_col_names_s
    faims_cv_pass[[s]] <- cv_pass_s
  }
  
  all_cov_cols <- unlist(cov_cols_out)
  if (cov_filter_remove) {
    n_before <- nrow(filt)
    cov_fail <- rowSums(sapply(all_cov_cols, function(cn)
      !is.na(filt[[cn]]) & filt[[cn]] >= cov_green)) == length(all_cov_cols)
    filt <- filt[!cov_fail, ]
    for (s in signal_samples)
      faims_cv_pass[[s]] <- faims_cv_pass[[s]][!cov_fail, ]
    cat(sprintf("\n%s — after CoV filter: %d of %d retained\n", source_tag, nrow(filt), n_before))
  }
  cat("\n")
  
  cov_meta <- setNames(
    lapply(all_cov_cols, function(cn) list(green = cov_green, yellow = cov_yellow)),
    all_cov_cols)
  write_xlsx_cov(filt, file_filtered, cov_meta)
  
  matched_raw <- match_lmsd(filt, lmsd_ref, adduct_cols, adduct_labels,
                            ppm_threshold, source_tag)
  
  if (nrow(matched_raw) > 0) {
    faims_filt_mz <- filt$mz
    passing_cvs_col <- vapply(seq_len(nrow(matched_raw)), function(i) {
      mz_i     <- matched_raw$mz[i]
      filt_idx <- which(faims_filt_mz == mz_i)
      if (length(filt_idx) == 0) return(NA_character_)
      filt_idx <- filt_idx[1]
      cvs_pass <- character(0)
      for (s in signal_samples) {
        pass_row <- faims_cv_pass[[s]][filt_idx, ]
        cvs_pass <- union(cvs_pass, cv_labels[pass_row])
      }
      if (length(cvs_pass) == 0) NA_character_ else paste(sort(cvs_pass), collapse = ", ")
    }, character(1))
    matched_raw$passing_CVs <- passing_cvs_col
    matched_raw <- matched_raw[!is.na(matched_raw$passing_CVs), ]
  } else {
    matched_raw$passing_CVs <- character(0)
  }
  
  matched <- collapse_to_sum_composition(matched_raw)
  cat(sprintf("%s — matched rows (before collapse): %d\n", source_tag, nrow(matched_raw)))
  cat(sprintf("%s — after sum-composition collapse: %d\n\n", source_tag, nrow(matched)))
  write_xlsx_cov(matched, file_matched, cov_meta)
  
  list(filt = filt, matched = matched, cov_meta = cov_meta,
       cov_cols = cov_cols_out, faims_cv_pass = faims_cv_pass)
}

