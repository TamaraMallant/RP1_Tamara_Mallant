count_zeros <- function(df, cols) {
  rowSums(df[, cols, drop = FALSE] == 0, na.rm = TRUE)
}

# IS matching: ±3 ppm
match_is <- function(df, is_df) {
  bind_rows(lapply(seq_len(nrow(df)), function(i) {
    ppm_errors <- ((df$mz[i] - is_df$is_mz) / is_df$is_mz) * 1e6
    hits <- which(abs(ppm_errors) <= 3)
    if (!length(hits)) return(NULL)
    bind_rows(lapply(hits, function(h)
      cbind(is_name = is_df$is_name[h], df[i, , drop = FALSE],
            ppm_error = ppm_errors[h])))
  }))
}

# Pareto scaling per row
pareto_scale <- function(mat) {
  out <- t(apply(mat, 1, function(x) {
    mu  <- mean(x, na.rm = TRUE)
    sig <- sd(x,   na.rm = TRUE)
    if (is.na(mu) || is.na(sig) || sig == 0) return(x - mu)
    (x - mu) / sqrt(sig)
  }))
  colnames(out) <- colnames(mat)
  out
}

run_ttest <- function(x, y) {
  x <- as.numeric(x[!is.na(x)]); y <- as.numeric(y[!is.na(y)])
  if (length(x) < 2 || length(y) < 2) return(NA_real_)
  alt <- if (mean(x) > mean(y)) "greater" else "less"
  tryCatch(t.test(x, y, alternative = alt, var.equal = FALSE)$p.value,
           error = function(e) NA_real_)
}

sig_label <- function(p) {
  if (is.na(p)) return("ns")
  if (p < 0.001) return("***")
  if (p < 0.01)  return("**")
  if (p < 0.05)  return("*")
  return("ns")
}

# CoV colour helper for openxlsx
add_cov_colours <- function(wb, sheet, col_idx, vals, start_row = 2) {
  for (i in seq_along(vals)) {
    v <- vals[i]
    fill <- if (is.na(v))           "#D3D3D3" else
      if (v < cov_green)  "#00B050" else
        if (v <= cov_yellow) "#FFFF00" else "#FF0000"
    addStyle(wb, sheet, createStyle(fgFill = fill),
             rows = start_row + i - 1, cols = col_idx, stack = TRUE)
  }
}

add_pvalue_colours <- function(wb, sheet, col_idx, vals, start_row = 2) {
  for (i in seq_along(vals)) {
    fill <- if (!is.na(vals[i]) && vals[i] < 0.05) "#00B050" else "#FFFFFF"
    addStyle(wb, sheet, createStyle(fgFill = fill),
             rows = start_row + i - 1, cols = col_idx, stack = TRUE)
  }
}

add_log2fc_colours <- function(wb, sheet, col_idx, vals, threshold = 1,
                               start_row = 2) {
  for (i in seq_along(vals)) {
    v <- vals[i]
    fill <- if (is.na(v))            "#D3D3D3" else
      if (v >  threshold)  "#00B050" else
        if (v < -threshold)  "#FF0000" else "#FFFFFF"
    addStyle(wb, sheet, createStyle(fgFill = fill),
             rows = start_row + i - 1, cols = col_idx, stack = TRUE)
  }
}


