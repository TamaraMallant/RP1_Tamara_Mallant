get_faims_best_long <- function(is_df, bv, condition_label, sample_label) {
  lapply(seq_len(nrow(is_df)), function(i) {
    reps <- bv$best_reps[[i]]
    data.frame(
      is_name   = is_df$is_name[i],
      abundance = reps,
      condition = condition_label,
      sample    = sample_label,
      group     = paste(sample_label, condition_label),
      stringsAsFactors = FALSE
    )
  }) |> bind_rows()
}

get_di_long <- function(is_df, sample_cols, condition_label, sample_label) {
