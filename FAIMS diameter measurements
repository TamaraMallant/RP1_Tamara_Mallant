best_cv_info <- function(is_df, sample_by_CV, label) {
  # Returns a named list with:
  #   $best_cv   — character vector of best cv_label per row
  #   $best_mean — numeric vector of best-CV mean abundance per row
  #   $best_reps — list of replicate vectors for the best CV
  means_mat <- do.call(cbind, lapply(seq_along(cv_labels), function(i) {
    cols <- intersect(sample_by_CV[[i]], colnames(is_df))
    rowMeans(is_df[, cols, drop = FALSE], na.rm = TRUE)
  }))
  best_idx  <- apply(means_mat, 1, which.max)
  best_cv   <- cv_labels[best_idx]
  best_mean <- apply(means_mat, 1, max, na.rm = TRUE)
  best_reps <- lapply(seq_len(nrow(is_df)), function(i) {
    cols <- intersect(sample_by_CV[[best_idx[i]]], colnames(is_df))
    as.numeric(is_df[i, cols])
  })
  list(best_cv = best_cv, best_mean = best_mean, best_reps = best_reps)
}

