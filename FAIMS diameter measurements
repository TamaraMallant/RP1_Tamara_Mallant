# =============================================================================
# SECTION 8 — DI PIPELINE (per-sample blank subtraction → IS matching)
# =============================================================================

run_di_pipeline <- function(raw_df, sample_cols, blank_cols, sample_label) {
  cat(sprintf("--- DI %s ---\n", sample_label))
  
  # Filter 1: Missingness
  df <- raw_df[count_zeros(raw_df, sample_cols) < missingness_count, ]
  cat(sprintf("  After missingness filter: %d / %d\n", nrow(df), nrow(raw_df)))
  
  # Filter 2: Abundance
  df <- df %>% mutate(across(all_of(sample_cols), as.numeric))
  df$.mean_sm <- rowMeans(df[, sample_cols, drop = FALSE], na.rm = TRUE)
  df <- df[df$.mean_sm >= abundance_threshold, ]
  cat(sprintf("  After abundance filter  : %d\n", nrow(df)))
  
  # Filter 3: Fold change vs own blank
  df$.mean_bl <- rowMeans(df[, blank_cols, drop = FALSE], na.rm = TRUE)
  df <- df[(df$.mean_sm + 1) / (df$.mean_bl + 1) >= fc_threshold, ]
  cat(sprintf("  After FC filter         : %d\n", nrow(df)))
  
  # CoV
  df$.sd_sm  <- apply(df[, sample_cols, drop = FALSE], 1, sd, na.rm = TRUE)
  df$.cov    <- df$.sd_sm / df$.mean_sm * 100
  
  if (filter_high_cov) {
    n_before <- nrow(df)
    df <- df[is.na(df$.cov) | df$.cov <= cov_yellow, ]
    cat(sprintf("  After CoV filter        : %d (removed %d)\n", nrow(df), n_before - nrow(df)))
  }
  
  # IS matching
  df_is <- match_is(df, is_ref)
  cat(sprintf("  IS-matched              : %d rows\n\n", nrow(df_is)))
  list(filtered = df, is_matched = df_is)
}

