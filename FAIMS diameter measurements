get_di_row_info <- function(is_df, lipid, sample_cols) {
  row_i <- which(is_df$is_name == lipid)
  if (!length(row_i)) {
    return(list(mz = NA_real_, ppm = NA_real_, mean_abu = NA_real_,
                cov = NA_real_, reps = rep(NA_real_, n_replicates)))
  }
  r   <- row_i[1]
  cols <- intersect(sample_cols, colnames(is_df))
  reps <- as.numeric(is_df[r, cols])
  mn   <- mean(reps, na.rm = TRUE)
  sd_v <- sd(reps, na.rm = TRUE)
  list(
    mz      = if ("mz" %in% colnames(is_df)) is_df$mz[r] else NA_real_,
    ppm     = if ("ppm_error" %in% colnames(is_df)) is_df$ppm_error[r] else NA_real_,
    mean_abu = mn,
    cov      = sd_v / mn * 100,
    reps     = reps
  )
}

get_faims_best_row_info <- function(is_df, lipid, bv) {
  row_i <- which(is_df$is_name == lipid)
  if (!length(row_i)) {
    return(list(mz = NA_real_, ppm = NA_real_, mean_abu = NA_real_,
                cov = NA_real_, best_cv = NA_character_,
                reps = rep(NA_real_, n_replicates)))
  }
  r    <- row_i[1]
  reps <- bv$best_reps[[r]]
  mn   <- mean(reps, na.rm = TRUE)
  sd_v <- sd(reps, na.rm = TRUE)
  list(
    mz       = if ("mz" %in% colnames(is_df)) is_df$mz[r] else NA_real_,
    ppm      = if ("ppm_error" %in% colnames(is_df)) is_df$ppm_error[r] else NA_real_,
    mean_abu  = mn,
    cov       = sd_v / mn * 100,
    best_cv   = bv$best_cv[r],
    reps      = reps
  )
}

rows_list <- lapply(all_is_lipids, function(lip) {
  
  # Theoretical m/z from IS reference
  theo_mz <- is_ref$is_mz[match(lip, is_ref$is_name)]
  
  d1  <- get_di_row_info(DI_IS1,    lip, DI_sample1_cols)
  f1  <- get_faims_best_row_info(FAIMS_IS1, lip, bv1)
  d2  <- get_di_row_info(DI_IS2,    lip, DI_sample2_cols)
  f2  <- get_faims_best_row_info(FAIMS_IS2, lip, bv2)
  
  # log2 FC  (S1 mean / S2 mean)
  fc_di    <- log2((d1$mean_abu + 1) / (d2$mean_abu + 1))
  fc_faims <- log2((f1$mean_abu + 1) / (f2$mean_abu + 1))
  
  # t-tests (one-sided, unequal var) — S1 vs S2, direction based on means
  p_di    <- run_ttest(d1$reps, d2$reps)
  p_faims <- run_ttest(f1$reps, f2$reps)
  
  # Within-sample DI vs FAIMS best-CV log2 FC and t-test
  fc_s1_di_vs_faims <- log2((f1$mean_abu + 1) / (d1$mean_abu + 1))
  p_s1_di_vs_faims  <- run_ttest(f1$reps, d1$reps)
  fc_s2_di_vs_faims <- log2((f2$mean_abu + 1) / (d2$mean_abu + 1))
  p_s2_di_vs_faims  <- run_ttest(f2$reps, d2$reps)
  
  # Highest abundance label
  abu_vec <- c(d1$mean_abu, f1$mean_abu, d2$mean_abu, f2$mean_abu)
  names(abu_vec) <- c(
    paste(sample1_name, "DI"),   paste(sample1_name, "FAIMS"),
    paste(sample2_name, "DI"),   paste(sample2_name, "FAIMS")
  )
  best_lbl <- if (all(is.na(abu_vec))) NA_character_ else
    names(which.max(abu_vec))
  
  data.frame(
    lipid_name              = lip,
    theoretical_mz          = round(theo_mz, 5),
    mz_S1_DI                = round(d1$mz, 5),
    ppm_S1_DI               = round(d1$ppm, 3),
    mean_abu_S1_DI          = round(d1$mean_abu, 0),
    CoV_S1_DI               = round(d1$cov, 1),
    mz_S1_FAIMS             = round(f1$mz, 5),
    ppm_S1_FAIMS            = round(f1$ppm, 3),
    mean_abu_S1_FAIMS_best  = round(f1$mean_abu, 0),
    CoV_S1_FAIMS_best       = round(f1$cov, 1),
    mz_S2_DI                = round(d2$mz, 5),
    ppm_S2_DI               = round(d2$ppm, 3),
    mean_abu_S2_DI          = round(d2$mean_abu, 0),
    CoV_S2_DI               = round(d2$cov, 1),
    mz_S2_FAIMS             = round(f2$mz, 5),
    ppm_S2_FAIMS            = round(f2$ppm, 3),
    mean_abu_S2_FAIMS_best  = round(f2$mean_abu, 0),
    CoV_S2_FAIMS_best       = round(f2$cov, 1),
    log2FC_DI_S1vsS2        = round(fc_di,    3),
    log2FC_FAIMS_S1vsS2     = round(fc_faims, 3),
    pval_DI_S1vsS2          = signif(p_di,    4),
    pval_FAIMS_S1vsS2       = signif(p_faims, 4),
    highest_abundance_in    = best_lbl,
    best_CV_S1_FAIMS        = f1$best_cv,
    best_CV_S2_FAIMS        = f2$best_cv,
    log2FC_S1_DI_vs_FAIMS   = round(fc_s1_di_vs_faims, 3),
    pval_S1_DI_vs_FAIMS     = signif(p_s1_di_vs_faims,  4),
    log2FC_S2_DI_vs_FAIMS   = round(fc_s2_di_vs_faims, 3),
    pval_S2_DI_vs_FAIMS     = signif(p_s2_di_vs_faims,  4),
    stringsAsFactors = FALSE
  )
})

