# =============================================================================
# SECTION 9 — FAIMS PIPELINE (per-sample blank subtraction → IS matching)
# =============================================================================

run_faims_pipeline <- function(raw_df, sample_by_CV, blank_by_CV, sample_label) {
  cat(sprintf("--- FAIMS %s ---\n", sample_label))
  
  # Filter 1: Missingness (pass if any CV has < missingness_count zeros)
  miss_ok <- do.call(cbind, lapply(seq_along(cv_labels), function(i)
    count_zeros(raw_df, sample_by_CV[[i]]) < missingness_count))
  df <- raw_df[rowSums(miss_ok) >= 1, ]
  cat(sprintf("  After missingness filter: %d / %d\n", nrow(df), nrow(raw_df)))
  
  # Filter 2: Abundance (pass if any CV mean >= threshold)
  abun_ok <- do.call(cbind, lapply(seq_along(cv_labels), function(i)
    rowMeans(df[, sample_by_CV[[i]], drop = FALSE], na.rm = TRUE) >= abundance_threshold))
  df <- df[rowSums(abun_ok) >= 1, ]
  cat(sprintf("  After abundance filter  : %d\n", nrow(df)))
  
  # Filter 3: FC per CV vs own blank
  fc_ok <- do.call(cbind, lapply(seq_along(cv_labels), function(i) {
    ms <- rowMeans(df[, sample_by_CV[[i]], drop = FALSE], na.rm = TRUE)
    mb <- rowMeans(df[, blank_by_CV[[i]],  drop = FALSE], na.rm = TRUE)
    (ms + 1) / (mb + 1) >= fc_threshold
  }))
  df <- df[rowSums(fc_ok) >= 1, ]
  cat(sprintf("  After FC filter         : %d\n", nrow(df)))
  
  # Per-CV mean and CoV
  for (i in seq_along(cv_labels)) {
    mn <- rowMeans(df[, sample_by_CV[[i]], drop = FALSE], na.rm = TRUE)
    sd_i <- apply(df[, sample_by_CV[[i]], drop = FALSE], 1, sd, na.rm = TRUE)
    df[[paste0(".mean_", cv_labels[i])]] <- mn
    df[[paste0(".cov_",  cv_labels[i])]] <- sd_i / mn * 100
  }
  
  if (filter_high_cov) {
    cov_cols_tmp <- paste0(".cov_", cv_labels)
    # Keep row if at least one CV has acceptable CoV
    any_ok <- rowSums(sapply(cov_cols_tmp, function(cn)
      is.na(df[[cn]]) | df[[cn]] <= cov_yellow)) > 0
    n_before <- nrow(df)
    df <- df[any_ok, ]
    cat(sprintf("  After CoV filter        : %d (removed %d)\n", nrow(df), n_before - nrow(df)))
  }
  
  df_is <- match_is(df, is_ref)
  cat(sprintf("  IS-matched              : %d rows\n\n", nrow(df_is)))
  list(filtered = df, is_matched = df_is)
}

