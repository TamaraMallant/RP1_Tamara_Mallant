make_di_faims_heatmap <- function(is_di, di_sample_cols,
                                  is_faims, faims_sample_by_CV,
                                  bv,
                                  sample_label,
                                  best_cv_only = TRUE,
                                  grey_threshold = grey_abundance_threshold) {
  
  all_lipids <- sort(unique(c(is_di$is_name, is_faims$is_name)))
  if (length(all_lipids) == 0) {
    cat("  No IS lipids found — heatmap skipped.\n"); return(invisible(NULL))
  }
  
  if (best_cv_only) {
    # Columns: DI reps | FAIMS-best-CV reps
    col_labels <- c(paste0("DI_rep", seq_len(n_replicates)),
                    paste0("FAIMS_best_rep", seq_len(n_replicates)))
    mat <- matrix(NA_real_, nrow = length(all_lipids), ncol = length(col_labels),
                  dimnames = list(all_lipids, col_labels))
    avail <- matrix(TRUE,  nrow = length(all_lipids), ncol = length(col_labels),
                    dimnames = list(all_lipids, col_labels))
    
    for (lip in all_lipids) {
      # DI
      row_di <- which(is_di$is_name == lip)
      if (length(row_di)) {
        cols <- intersect(di_sample_cols, colnames(is_di))
        mat[lip, paste0("DI_rep", seq_len(n_replicates))] <-
          as.numeric(is_di[row_di[1], cols])
      } else {
        avail[lip, paste0("DI_rep", seq_len(n_replicates))] <- FALSE
      }
      # FAIMS best CV
      row_fa <- which(is_faims$is_name == lip)
      if (length(row_fa)) {
        mat[lip, paste0("FAIMS_best_rep", seq_len(n_replicates))] <-
          bv$best_reps[[row_fa[1]]]
      } else {
        avail[lip, paste0("FAIMS_best_rep", seq_len(n_replicates))] <- FALSE
      }
    }
    block_sizes <- c(n_replicates, n_replicates)
    x_labels <- c(paste0("DI Rep ", seq_len(n_replicates)),
                  paste0("FAIMS Best-CV Rep ", seq_len(n_replicates)))
  } else {
    # Columns: DI reps | CV1 reps | CV2 reps | ...
    cv_block_cols <- unlist(lapply(cv_labels, function(cv)
      paste0("FAIMS_", cv, "_rep", seq_len(n_replicates))))
    col_labels <- c(paste0("DI_rep", seq_len(n_replicates)), cv_block_cols)
    x_labels   <- c(paste0("DI Rep ",   seq_len(n_replicates)),
                    unlist(lapply(cv_labels, function(cv)
                      paste0(cv, " Rep ", seq_len(n_replicates)))))
    mat  <- matrix(NA_real_, nrow = length(all_lipids), ncol = length(col_labels),
                   dimnames = list(all_lipids, col_labels))
    avail <- matrix(TRUE, nrow = length(all_lipids), ncol = length(col_labels),
                    dimnames = list(all_lipids, col_labels))
    
    for (lip in all_lipids) {
      row_di <- which(is_di$is_name == lip)
      if (length(row_di)) {
        cols <- intersect(di_sample_cols, colnames(is_di))
        mat[lip, paste0("DI_rep", seq_len(n_replicates))] <-
          as.numeric(is_di[row_di[1], cols])
      } else {
        avail[lip, paste0("DI_rep", seq_len(n_replicates))] <- FALSE
      }
      row_fa <- which(is_faims$is_name == lip)
      for (i in seq_along(cv_labels)) {
        cv_cols_out <- paste0("FAIMS_", cv_labels[i], "_rep", seq_len(n_replicates))
        if (length(row_fa)) {
          cols_in <- intersect(faims_sample_by_CV[[i]], colnames(is_faims))
          vals    <- as.numeric(is_faims[row_fa[1], cols_in])
          mat[lip, cv_cols_out] <- vals
          # Grey out if mean abundance is below threshold
          if (!is.na(mean(vals, na.rm = TRUE)) &&
              mean(vals, na.rm = TRUE) < grey_threshold)
            avail[lip, cv_cols_out] <- FALSE
        } else {
          avail[lip, cv_cols_out] <- FALSE
        }
      }
    }
    block_sizes <- c(n_replicates, rep(n_replicates, n_cv))
  }
  
  # Scale
  mat_log <- log2(mat); mat_log[!is.finite(mat_log)] <- NA
  mat_imp <- mat_log
  for (i in seq_len(nrow(mat_imp))) {
    na_i <- is.na(mat_imp[i, ])
    if (any(na_i)) mat_imp[i, na_i] <- median(mat_imp[i, ], na.rm = TRUE)
  }
  mat_imp[!is.finite(mat_imp)] <- 0
  scaled <- if (pareto_scaling) pareto_scale(mat_imp) else mat_imp
  colnames(scaled) <- col_labels
  
  # Row order by clustering
  row_ord <- tryCatch(
    rownames(scaled)[hclust(dist(scaled), method = "complete")$order],
    error = function(e) rownames(scaled)
  )
  
  # Long format
  long_h <- data.frame(
    y_label = rep(rownames(scaled), times = ncol(scaled)),
    x_label = rep(x_labels,         each  = nrow(scaled)),
    value   = as.vector(scaled),
    avail   = as.vector(avail)
  ) %>%
    mutate(
      value   = ifelse(avail, value, NA_real_),
      x_label = factor(x_label, levels = x_labels),
      y_label = factor(y_label, levels = rev(row_ord))
    )
  
  x_sep <- cumsum(block_sizes)
  x_sep <- x_sep[-length(x_sep)] + 0.5
  sl    <- max(abs(range(long_h$value, na.rm = TRUE)), na.rm = TRUE)
  mc    <- c("#00008B","#0000FF","#4169E1","#87CEEB","#FFFFFF",
             "#FFB6C1","#FF4500","#FF0000","#8B0000")
  ph    <- max(6, length(all_lipids) * 0.30)
  pw    <- length(col_labels) * 0.55 + 4
  
  type_tag <- if (best_cv_only) "best_CV" else "all_CVs"
  subtitle <- paste0(
    if (pareto_scaling) "log2 | Pareto scaled" else "log2 | no scaling",
    if (!best_cv_only) sprintf(" | grey = mean abundance < %s",
                               format(grey_threshold, big.mark = ",")) else "",
    " | grey = not detected | rows clustered"
  )
  
  p <- ggplot(long_h, aes(x = x_label, y = y_label, fill = value)) +
    geom_tile(colour = "white", linewidth = 0.25) +
    { lapply(x_sep, function(xs)
      geom_vline(xintercept = xs, colour = "grey30", linewidth = 0.8)) } +
    scale_fill_gradientn(colours = mc, limits = c(-sl, sl), na.value = "grey85",
                         name = if (pareto_scaling) "Pareto-scaled\nlog2" else "log2(abundance)") +
    scale_x_discrete(position = "top") +
    scale_y_discrete(expand = c(0, 0)) +
    labs(title    = sprintf("IS lipid heatmap — %s | %s (%s mode)",
                            sample_label, type_tag, toupper(mode)),
         subtitle = subtitle,
         x = NULL, y = "IS lipid") +
    theme_minimal(base_size = 10) +
    theme(axis.text.x       = element_text(angle = 40, hjust = 0, vjust = 0, size = 9),
          axis.text.y       = element_text(size = 8),
          legend.key.height = unit(1.5, "cm"),
          panel.grid        = element_blank(),
          plot.title        = element_text(face = "bold"))
  
  out_stem <- file.path(data_dir,
                        sprintf("heatmap_%s_%s_%s", sample_label, type_tag, mode))
  ggsave(paste0(out_stem, ".pdf"), p, width = pw, height = ph, limitsize = FALSE)
  ggsave(paste0(out_stem, ".png"), p, width = pw, height = ph,
         limitsize = FALSE, dpi = 180)
  cat(sprintf("  Heatmap saved: %s\n", basename(out_stem)))
  invisible(p)
}


